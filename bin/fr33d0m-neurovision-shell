#!/usr/bin/env bash
set -euo pipefail

export TERM="${TERM:-xterm-256color}"

# ttyd can launch the child before the browser has finished negotiating
# the terminal size. Neurovision exits immediately when started against a
# 0x0 terminal, so wait briefly for a usable PTY before launching it.
for _ in $(seq 1 120); do
  size="$(stty size 2>/dev/null || printf '0 0')"
  rows="${size%% *}"
  cols="${size##* }"
  if [ "${rows:-0}" -gt 0 ] 2>/dev/null && [ "${cols:-0}" -gt 0 ] 2>/dev/null; then
    break
  fi
  sleep 0.05
done

# Launch through an interactive shell so Neurovision sees the same terminal
# environment as the working browser terminal path. If Neurovision exits, keep
# the shell open instead of causing a reconnect loop.
rc_file="$(mktemp /tmp/fr33d0m-neurovision-rc.XXXXXX)"
cat > "$rc_file" <<'EOF'
clear
fr33d0m-neurovision --gallery
printf '\n\nNeurovision exited. Use `fr33d0m-neurovision --gallery` to relaunch.\n'
exec bash -il
EOF

exec bash --init-file "$rc_file" -i
