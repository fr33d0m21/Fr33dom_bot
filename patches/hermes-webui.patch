+      }
+    }
+
+    setNotice({ tone: 'info', text: 'Reloaded the latest file state.' })
+  }
+
+  const handleDraftChange = (value: string) => {
+    if (!activeContent) return
+    setNotice(null)
+    setDraft({
+      path: activeContent.path,
+      revision: activeContent.revision,
+      content: value,
+    })
+  }
+
+  const handleSave = () => {
+    if (!activeContent || !activeRootId) return
+    updateMutation.mutate({
+      root_id: activeRootId,
+      path: activeContent.path,
+      revision: activeContent.revision,
+      content: draftContent,
+    })
+  }
+
+  const handleUpload = (file: File) => {
+    if (!activeRootId) return
+
+    if (file.size > MAX_UPLOAD_BYTES) {
+      setNotice({
+        tone: 'error',
+        text: 'Upload rejected over 50 MB. Choose a smaller file and try again.',
