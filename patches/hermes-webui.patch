+"""Curated personality file endpoints (revision-aware inline editing)."""
+
+from pathlib import Path
+
+from fastapi import APIRouter, Depends, HTTPException
+
+from webui import hermes_bridge
+from webui.auth import require_auth
+from webui.dashboard_settings import load_dashboard_settings
+from webui.runtime_fs import (
+    max_inline_edit_bytes_cap,
+    resolve_personality_file,
+    revision_token,
+    text_binary_probe,
+)
+from webui.schemas.personality import (
+    PersonalityDetailResponse,
+    PersonalityListResponse,
+    PersonalitySummary,
+    PersonalityUpdateRequest,
+    PersonalityUpdateResponse,
+)
+
+router = APIRouter(prefix="/api/personality", tags=["personality"], dependencies=[Depends(require_auth)])
+
+
+def _hermes_home() -> Path:
+    """Runtime Hermes home (reads current `hermes_bridge.HERMES_HOME` for test patches)."""
+    return hermes_bridge.HERMES_HOME
+
+
+def _load_settings():
+    return load_dashboard_settings(hermes_home=_hermes_home())
+
+
+def _home() -> Path:
+    return Path.home()
+
+
+def _read_utf8_text_if_supported(path: Path) -> str | None:
+    """Read a curated file only when it is valid UTF-8 text."""
+    if text_binary_probe(path) != "text":
+        return None
+    try:
+        return path.read_text(encoding="utf-8")
+    except (OSError, UnicodeDecodeError):
+        return None
+
+
+def _summarize(ref_id: str) -> PersonalitySummary | None:
+    settings = _load_settings()
+    resolved = resolve_personality_file(
+        settings, ref_id, home=_home(), hermes_home=_hermes_home()
+    )
+    if resolved is None:
+        return None
+    ref, path = resolved
+    exists = path.is_file()
+    rev = revision_token(path) if exists else "0"
+    size: int | None = None
+    kind: str | None = None
+    if exists:
+        try:
+            size = path.stat().st_size
+            kind = text_binary_probe(path)
+        except OSError:
+            kind = "binary"
+    return PersonalitySummary(
+        id=ref.id,
+        label=ref.label,
+        root_id=ref.root_id,
+        path=ref.path,
+        resolved_path=str(path),
+        exists=exists,
+        revision=rev,
+        size=size,
+        kind=kind,
+    )
+
+
+@router.get("", response_model=PersonalityListResponse)
+async def list_personality():
+    """List curated personality files from dashboard settings."""
+    settings = _load_settings()
+    entries: list[PersonalitySummary] = []
+    for pref in settings.personality_files:
+        row = _summarize(pref.id)
+        if row is not None:
+            entries.append(row)
+    return PersonalityListResponse(entries=entries)
+
+
+@router.get("/{personality_id}", response_model=PersonalityDetailResponse)
+async def get_personality(personality_id: str):
+    """Return one curated personality file with content and revision."""
+    settings = _load_settings()
+    resolved = resolve_personality_file(
+        settings, personality_id, home=_home(), hermes_home=_hermes_home()
+    )
+    if resolved is None:
+        raise HTTPException(status_code=404, detail="Personality not found")
+    ref, path = resolved
+    exists = path.is_file()
+    rev = revision_token(path) if exists else "0"
+    content = ""
+    size: int | None = None
+    kind: str | None = None
+    if exists:
+        try:
+            st = path.stat()
+            size = st.st_size
+            text_content = _read_utf8_text_if_supported(path)
+            if text_content is None:
+                kind = "binary"
+                content = ""
+            else:
+                kind = "text"
+                content = text_content
+        except OSError:
+            kind = "binary"
+    return PersonalityDetailResponse(
+        id=ref.id,
+        label=ref.label,
+        root_id=ref.root_id,
+        path=ref.path,
+        resolved_path=str(path),
+        exists=exists,
+        revision=rev,
+        content=content,
+        size=size,
+        kind=kind,
+    )
+
+
+@router.put("/{personality_id}", response_model=PersonalityUpdateResponse)
+async def put_personality(personality_id: str, req: PersonalityUpdateRequest):
+    """Write personality content if the expected revision still matches."""
+    settings = _load_settings()
+    resolved = resolve_personality_file(
+        settings, personality_id, home=_home(), hermes_home=_hermes_home()
+    )
+    if resolved is None:
+        raise HTTPException(status_code=404, detail="Personality not found")
+    _ref, path = resolved
+    if path.is_file() and _read_utf8_text_if_supported(path) is None:
+        raise HTTPException(
+            status_code=415,
+            detail="Personality file is not text; refusing overwrite",
+        )
+    cap = max_inline_edit_bytes_cap(settings)
+    raw = req.content.encode("utf-8")
+    if len(raw) > cap:
+        raise HTTPException(
+            status_code=413,
+            detail=f"Content exceeds max inline edit size ({cap} bytes)",
+        )
+    current = revision_token(path) if path.is_file() else "0"
+    if current != req.revision:
+        raise HTTPException(status_code=409, detail="Stale revision")
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(req.content, encoding="utf-8")
+    new_rev = revision_token(path)
+    return PersonalityUpdateResponse(revision=new_rev)
