index 0000000..06ae51f
--- /dev/null
+++ b/frontend/src/pages/Personality.tsx
@@ -0,0 +1,448 @@
+import { useMemo, useState } from 'react'
+import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query'
+import { Link } from 'react-router-dom'
+import { api } from '../api/client'
+import type { PersonalityDetailResponse, PersonalitySummary } from '../api/types'
+import { TextFileEditor, type EditorNotice, type TextEditorMetaItem } from '../components/editor/TextFileEditor'
+import { PersonalityEntryList } from '../components/personality/PersonalityEntryList'
+import { entryTitle } from '../components/personality/labels'
+
+type PersonalityEntry = PersonalitySummary | PersonalityDetailResponse
+const EMPTY_ENTRIES: PersonalitySummary[] = []
+
+interface ParsedApiError {
+  status: number | null
+  detail: string
+  message: string
+}
+
+interface DraftState {
+  personalityId: string | null
+  revision: string | null
+  content: string
+}
+
+function formatBytes(size: number | null): string {
+  if (size === null) return 'Unknown'
+  if (size < 1024) return `${size} B`
+  if (size < 1024 * 1024) return `${(size / 1024).toFixed(1)} KB`
+  return `${(size / (1024 * 1024)).toFixed(1)} MB`
+}
+
+function entryKind(entry: PersonalityEntry): string {
+  if (!entry.exists) return 'missing'
+  return entry.kind || 'unknown'
+}
+
+function parentPath(path: string): string {
+  if (!path) return ''
+  const index = path.lastIndexOf('/')
+  return index === -1 ? '' : path.slice(0, index)
+}
+
+function buildFilesHref(rootId: string, path: string): string {
+  const search = new URLSearchParams({ root: rootId })
+  const folder = parentPath(path)
+  if (folder) {
+    search.set('folder', folder)
+  }
+  return `/files?${search.toString()}`
+}
+
+function parseApiError(error: unknown): ParsedApiError {
+  const message = error instanceof Error ? error.message : 'Unexpected error'
+  const apiMatch = message.match(/^API error (\d+):\s*(.*)$/s)
+
+  if (!apiMatch) {
+    return { status: null, detail: message, message }
+  }
+
+  const status = Number(apiMatch[1])
+  const body = apiMatch[2].trim()
+  let detail = body
+
+  if (body) {
+    try {
+      const parsed = JSON.parse(body) as { detail?: unknown }
+      if (typeof parsed.detail === 'string') {
+        detail = parsed.detail
+      }
+    } catch {
+      detail = body
+    }
+  }
+
+  return { status, detail, message }
+}
+
+function isPermissionError(error: ParsedApiError): boolean {
+  return (
+    error.status === 403 ||
+    /permission|forbidden|not allowed|denied/i.test(`${error.detail} ${error.message}`)
+  )
+}
+
+function loadFailureMessage(error: unknown, fallback: string): string {
+  const parsed = parseApiError(error)
+  if (isPermissionError(parsed)) {
+    return 'Permission denied. Check filesystem access for this curated file.'
+  }
+  return parsed.detail || fallback
+}
+
+function EditorStatePanel({
+  title,
+  description,
+  actionLabel,
+  onAction,
+  busy = false,
+}: {
+  title: string
+  description: string
+  actionLabel?: string
+  onAction?: () => void
+  busy?: boolean
+}) {
+  return (
+    <div
+      className="rounded-lg border border-dashed p-5 space-y-3"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)' }}
+    >
+      <div className="space-y-1">
+        <h4 className="text-sm font-medium" style={{ color: 'var(--color-text)' }}>
+          {title}
+        </h4>
+        <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+          {description}
+        </p>
+      </div>
+      {actionLabel && onAction && (
+        <button
+          type="button"
+          onClick={onAction}
+          disabled={busy}
+          className="rounded-lg px-3 py-2 text-sm font-medium"
+          style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+        >
+          {busy ? 'Working...' : actionLabel}
+        </button>
+      )}
+    </div>
+  )
+}
+
+export function Personality() {
+  const queryClient = useQueryClient()
+  const [selectedId, setSelectedId] = useState<string | null>(null)
+  const [draft, setDraft] = useState<DraftState>({
+    personalityId: null,
+    revision: null,
+    content: '',
+  })
+  const [notice, setNotice] = useState<EditorNotice | null>(null)
+
+  const listQuery = useQuery({
+    queryKey: ['personality-list'],
+    queryFn: api.personalityList,
+  })
+
+  const entries = listQuery.data?.entries ?? EMPTY_ENTRIES
+
+  const effectiveSelectedId = useMemo(() => {
+    if (selectedId && entries.some((entry) => entry.id === selectedId)) {
+      return selectedId
+    }
+    return entries.find((entry) => entry.exists)?.id || entries[0]?.id || null
+  }, [entries, selectedId])
+
+  const detailQuery = useQuery({
+    queryKey: ['personality-detail', effectiveSelectedId],
+    queryFn: () => api.personalityDetail(effectiveSelectedId as string),
+    enabled: Boolean(effectiveSelectedId),
+  })
+
+  const detail = detailQuery.data || null
+
+  const selectedEntry = useMemo(
+    () => entries.find((entry) => entry.id === effectiveSelectedId) || null,
+    [effectiveSelectedId, entries],
+  )
+
+  const activeEntry = detail || selectedEntry
+  const filesHref = activeEntry ? buildFilesHref(activeEntry.root_id, activeEntry.path) : null
+  const draftContent =
+    detail && draft.personalityId === detail.id && draft.revision === detail.revision
+      ? draft.content
+      : detail?.content || ''
+  const hasUnsavedChanges = detail ? draftContent !== detail.content : false
+  const canEditInline = detail ? detail.kind !== 'binary' : false
+
+  const updateMutation = useMutation({
+    mutationFn: (variables: { personalityId: string; content: string; revision: string }) =>
+      api.updatePersonality(variables.personalityId, {
+        content: variables.content,
+        revision: variables.revision,
+      }),
+    onMutate: () => {
+      setNotice(null)
+    },
+    onSuccess: (result, variables) => {
+      const currentDetail = queryClient.getQueryData<PersonalityDetailResponse>([
+        'personality-detail',
+        variables.personalityId,
+      ])
+      const createdFromMissing = Boolean(currentDetail && !currentDetail.exists)
+      const nextSize = new TextEncoder().encode(variables.content).length
+
+      queryClient.setQueryData<PersonalityDetailResponse | undefined>(
+        ['personality-detail', variables.personalityId],
+        (current) =>
+          current
+            ? {
+                ...current,
+                content: variables.content,
+                revision: result.revision,
+                exists: true,
+                size: nextSize,
+                kind: 'text',
+              }
+            : current,
+      )
+
+      setDraft({
+        personalityId: variables.personalityId,
+        revision: result.revision,
+        content: variables.content,
+      })
+      void queryClient.invalidateQueries({ queryKey: ['personality-list'] })
+      setNotice({
+        tone: 'success',
+        text: createdFromMissing ? 'Created the missing curated file.' : 'Saved personality changes.',
+      })
+    },
+    onError: (error) => {
+      const parsed = parseApiError(error)
+      if (parsed.status === 409) {
+        setNotice({
+          tone: 'error',
+          text: 'This file changed on disk. Reload the latest revision before saving again.',
+        })
+        return
+      }
+      if (isPermissionError(parsed)) {
+        setNotice({
+          tone: 'error',
+          text: 'Permission denied. Check filesystem permissions for this curated file and try again.',
+        })
+        return
+      }
+      setNotice({
+        tone: 'error',
+        text: parsed.detail || 'Failed to save the curated personality file.',
+      })
+    },
+  })
+
+  const handleSelect = (nextId: string) => {
+    setNotice(null)
+    setSelectedId(nextId)
+  }
+
+  const handleDraftChange = (value: string) => {
+    if (!detail) return
+    setNotice(null)
+    setDraft({
+      personalityId: detail.id,
+      revision: detail.revision,
+      content: value,
+    })
+  }
+
+  const handleSave = () => {
+    if (!effectiveSelectedId || !detail) return
+    updateMutation.mutate({
+      personalityId: effectiveSelectedId,
+      content: draftContent,
+      revision: detail.revision,
+    })
+  }
+
+  const handleReload = async () => {
+    if (!effectiveSelectedId) return
+    setNotice(null)
+    const result = await detailQuery.refetch()
+
+    if (result.data) {
+      setDraft({
+        personalityId: result.data.id,
+        revision: result.data.revision,
+        content: result.data.content,
+      })
+      setNotice({ tone: 'info', text: 'Reloaded the latest file contents.' })
+      return
+    }
+
+    if (result.error) {
+      setNotice({
+        tone: 'error',
+        text: loadFailureMessage(result.error, 'Failed to reload the curated personality file.'),
+      })
+    }
+  }
+
+  const handleCopyPath = async () => {
+    if (!activeEntry) return
+    setNotice(null)
+    try {
+      await navigator.clipboard.writeText(activeEntry.resolved_path)
+      setNotice({ tone: 'success', text: 'Copied the resolved path to the clipboard.' })
+    } catch {
+      setNotice({ tone: 'error', text: 'Unable to copy the resolved path to the clipboard.' })
+    }
+  }
+
+  const metaItems: TextEditorMetaItem[] = activeEntry
+    ? [
+        { label: 'Root', value: activeEntry.root_id },
+        { label: 'Relative Path', value: activeEntry.path },
+        { label: 'Resolved Path', value: activeEntry.resolved_path },
+        { label: 'Status', value: activeEntry.exists ? 'present' : 'missing' },
+        { label: 'Kind', value: entryKind(activeEntry) },
+        { label: 'Revision', value: activeEntry.revision },
+        { label: 'Size', value: formatBytes(activeEntry.size) },
+      ]
+    : []
+
+  const listErrorMessage = listQuery.error
+    ? loadFailureMessage(listQuery.error, 'Failed to load curated personality files.')
+    : null
+
+  return (
+    <div className="p-6 flex flex-col gap-6 md:h-full">
+      <div className="space-y-2">
+        <h2 className="text-2xl font-semibold">Personality</h2>
+        <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+          Edit curated runtime personality files with a simple left rail and inline text editor.
+        </p>
+      </div>
+
+      <div className="grid gap-4 xl:grid-cols-[280px_minmax(0,1fr)]">
+        <PersonalityEntryList
+          entries={entries}
+          selectedId={effectiveSelectedId}
+          isLoading={listQuery.isLoading}
+          errorMessage={listErrorMessage}
+          onSelect={handleSelect}
+        />
+
+        <TextFileEditor
+          title={activeEntry ? entryTitle(activeEntry) : 'Personality File'}
+          description="Visible metadata stays attached to the current file so you can verify what you are editing before saving."
+          metaItems={metaItems}
+          notice={notice}
+          actions={
+            <>
+              <button
+                type="button"
+                onClick={handleCopyPath}
+                disabled={!activeEntry}
+                className="rounded-lg px-3 py-2 text-sm font-medium disabled:opacity-50"
+                style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+              >
+                Copy path
+              </button>
+              {filesHref && (
+                <Link
+                  to={filesHref}
+                  className="rounded-lg px-3 py-2 text-sm font-medium no-underline"
+                  style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+                >
+                  Open in Files
+                </Link>
+              )}
+              <button
+                type="button"
+                onClick={() => {
+                  void handleReload()
+                }}
+                disabled={!effectiveSelectedId || detailQuery.isFetching}
+                className="rounded-lg px-3 py-2 text-sm font-medium disabled:opacity-50"
+                style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+              >
+                {detailQuery.isFetching ? 'Reloading...' : 'Reload'}
+              </button>
+              <button
+                type="button"
+                onClick={handleSave}
+                disabled={!detail || !canEditInline || !hasUnsavedChanges || updateMutation.isPending}
+                className="rounded-lg px-4 py-2 text-sm font-medium disabled:opacity-50"
+                style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+              >
+                {updateMutation.isPending ? 'Saving...' : 'Save'}
+              </button>
+            </>
+          }
+        >
+          {!effectiveSelectedId && !listQuery.isLoading && !listErrorMessage && (
+            <EditorStatePanel
+              title="No curated file selected"
+              description="Add a curated file to dashboard settings or choose one from the left rail to begin editing."
+            />
+          )}
+
+          {effectiveSelectedId && detailQuery.isLoading && (
+            <EditorStatePanel
+              title="Loading curated file"
+              description="Fetching the latest curated personality content from disk."
+            />
+          )}
+
+          {effectiveSelectedId && detailQuery.error && (
+            <EditorStatePanel
+              title={isPermissionError(parseApiError(detailQuery.error)) ? 'Permission denied' : 'Could not load curated file'}
+              description={loadFailureMessage(detailQuery.error, 'Failed to load the selected curated file.')}
+              actionLabel="Retry"
+              onAction={() => {
+                void handleReload()
+              }}
+              busy={detailQuery.isFetching}
+            />
+          )}
+
+          {detail && !detailQuery.error && (
+            <div className="space-y-4">
+              {!detail.exists && (
+                <div
+                  className="rounded-lg border border-dashed p-4 text-sm"
+                  style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)', color: 'var(--color-warning)' }}
+                >
+                  This curated file is missing on disk. Edit below and save to create it at the configured path.
+                </div>
+              )}
+
+              {detail.kind === 'binary' ? (
+                <EditorStatePanel
+                  title="Inline editing unavailable"
+                  description="This curated file is not plain text, so the dashboard will not overwrite it inline."
+                />
+              ) : (
+                <textarea
+                  aria-label="Personality content"
+                  value={draftContent}
+                  onChange={(event) => handleDraftChange(event.target.value)}
+                  placeholder="Write the curated personality content here..."
+                  className="min-h-[420px] w-full rounded-lg border p-3 text-sm font-mono outline-none"
+                  style={{
+                    borderColor: 'var(--color-border)',
+                    backgroundColor: 'var(--color-bg)',
+                    color: 'var(--color-text)',
+                  }}
+                />
+              )}
+            </div>
+          )}
+        </TextFileEditor>
+      </div>
+    </div>
+  )
+}
