+import { FileMetadataPanel, type FileMetadataItem } from '../components/files/FileMetadataPanel'
+
+const MAX_UPLOAD_BYTES = 50 * 1024 * 1024
+
+interface ParsedApiError {
+  status: number | null
+  detail: string
+  message: string
+}
+
+interface DraftState {
+  path: string | null
+  revision: string | null
+  content: string
+}
