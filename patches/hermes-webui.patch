@@ -0,0 +1,400 @@
+"""Safe path helpers for runtime file browsing and inline editing."""
+
+from __future__ import annotations
+
+import os
+from pathlib import Path
+from typing import Iterable, Sequence
+
+from webui.dashboard_settings import (
+    DEFAULT_MAX_INLINE_EDIT_BYTES,
+    DashboardSettings,
+    FileRoot,
+    PersonalityFileRef,
+)
+
+FR33DOM_BOT_DIR = "Fr33dom_bot"
+
+DEFAULT_MAX_INLINE_BYTES = DEFAULT_MAX_INLINE_EDIT_BYTES
+_TEXT_PROBE_BYTES = 8192
+MANAGED_PATH_DETAIL = "Path is managed by the Personality API"
+HIDDEN_PATH_DETAIL = "Path is hidden from the Files API"
+
+
+class PathTraversalError(ValueError):
+    """Relative path contained a forbidden `..` segment."""
+
+
+class AbsolutePathInRelativeError(ValueError):
+    """Relative path was absolute or used `~` expansion outside the root."""
+
+
+class PathOutsideRootError(ValueError):
+    """Resolved path escaped its root (including via symlinks)."""
+
+
+class Fr33domBotExposureError(ValueError):
+    """Path would expose the Fr33dom_bot tree, which is blocked for generic browsing."""
+
+
+def find_file_root(roots: Sequence[FileRoot], root_id: str) -> FileRoot | None:
+    """Return the file root with the given id, or None."""
+    for r in roots:
+        if r.id == root_id:
+            return r
+    return None
+
+
+def resolve_personality_file(
+    settings: DashboardSettings,
+    personality_id: str,
+    *,
+    home: Path,
+    hermes_home: Path,
+) -> tuple[PersonalityFileRef, Path] | None:
+    """Resolve a curated personality file id to its ref and absolute path, or None if invalid."""
+    ref: PersonalityFileRef | None = None
+    for p in settings.personality_files:
+        if p.id == personality_id:
+            ref = p
+            break
+    if ref is None:
+        return None
+    root = find_file_root(settings.file_roots, ref.root_id)
+    if root is None:
+        return None
+    try:
+        root_dir = resolve_root_directory(root, home=home, hermes_home=hermes_home)
+        target = resolve_under_root(root_dir, ref.path, home=home)
+    except (Fr33domBotExposureError, PathOutsideRootError, PathTraversalError, AbsolutePathInRelativeError):
+        return None
+    return (ref, target)
+
+
+def expand_dashboard_path(path_str: str, *, home: Path, hermes_home: Path) -> Path:
+    """Expand dashboard path strings using explicit home and HERMES_HOME (test-friendly)."""
+    s = path_str.strip()
+    if s == "~/.hermes" or s.startswith("~/.hermes/"):
+        rest = s.removeprefix("~/.hermes").lstrip("/")
+        return hermes_home / rest if rest else hermes_home
+    if s.startswith("~/"):
+        rest = s[2:].lstrip("/")
+        return home / rest if rest else home
+    if s.startswith("~"):
+        return Path(os.path.expanduser(s))
+    return Path(s).expanduser()
+
+
+def resolve_root_directory(root: FileRoot, *, home: Path, hermes_home: Path) -> Path:
+    """Resolve a configured root path on disk and validate it is allowed."""
+    p = expand_dashboard_path(root.path, home=home, hermes_home=hermes_home)
+    return validate_root_path(p, home=home)
+
+
+def validate_root_path(path: Path, *, home: Path) -> Path:
+    """Resolve a candidate root directory; reject Fr33dom_bot exposure."""
+    resolved = path.resolve()
+    if _is_fr33dom_bot_exposure(resolved, home=home):
+        raise Fr33domBotExposureError(str(resolved))
+    return resolved
+
+
+def normalize_relative(rel: str) -> str:
+    """Normalize a relative path: strip, POSIX separators, forbid `..` segments."""
+    if not rel or not rel.strip():
+        return ""
+    s = rel.strip().replace("\\", "/")
+    if s.startswith("/"):
+        raise AbsolutePathInRelativeError("absolute path not allowed")
+    if s.startswith("~"):
+        raise AbsolutePathInRelativeError("tilde expansion not allowed in relative segments")
+    parts: list[str] = []
+    for seg in s.split("/"):
+        if seg in ("", "."):
+            continue
+        if seg == "..":
+            raise PathTraversalError(rel)
+        parts.append(seg)
+    return "/".join(parts)
+
+
+def _is_fr33dom_bot_exposure(resolved: Path, *, home: Path) -> bool:
+    """True if resolved path is Fr33dom_bot, inside it, or an ancestor that could reach it.
+
+    Uses canonical paths only — does not require Fr33dom_bot to exist on disk yet.
+    """
+    fb = (home / FR33DOM_BOT_DIR).resolve()
+    res = resolved.resolve()
+    if res == fb:
+        return True
+    try:
+        res.relative_to(fb)
+        return True
+    except ValueError:
+        pass
+    try:
+        fb.relative_to(res)
+        return True
+    except ValueError:
+        return False
+
+
+def _is_under(parent: Path, child: Path) -> bool:
+    pr = parent.resolve()
+    cr = child.resolve()
+    if cr == pr:
+        return True
+    try:
+        cr.relative_to(pr)
+        return True
+    except ValueError:
+        return False
+
+
+def resolve_under_root(
+    root_dir: Path,
+    relative: str,
+    *,
+    home: Path,
+) -> Path:
+    """Join and resolve `relative` under `root_dir`, blocking traversal and Fr33dom_bot."""
+    root_res = root_dir.resolve()
+    norm = normalize_relative(relative)
+    target = (root_res / norm) if norm else root_res
+    target = target.resolve()
+    if not _is_under(root_res, target):
+        raise PathOutsideRootError(str(target))
+    if _is_fr33dom_bot_exposure(target, home=home):
+        raise Fr33domBotExposureError(str(target))
+    return target
+
+
+def resolve_with_symlinks_checked(
+    root_dir: Path,
+    relative: str,
+    *,
+    home: Path,
+) -> Path:
+    """Same as resolve_under_root (symlinks are followed by resolve())."""
+    return resolve_under_root(root_dir, relative, home=home)
+
+
+def first_symlink_alias(root_dir: Path, relative: str) -> Path | None:
+    """Return the first symlink encountered along a requested relative path, if any."""
+    norm = normalize_relative(relative)
+    if not norm:
+        return None
+
+    current = root_dir.resolve()
+    for segment in norm.split("/"):
+        current = current / segment
+        try:
+            if current.is_symlink():
+                return current
+        except OSError:
+            return None
+
+    return None
+
+
+def revision_token(path: Path) -> str:
+    """Stable revision id from filesystem mtime (nanoseconds)."""
+    try:
+        return str(path.stat().st_mtime_ns)
+    except OSError:
+        return "0"
+
+
+def text_binary_probe(path: Path) -> str:
+    """Lightweight UTF-8 text vs binary guess from the first chunk."""
+    try:
+        with path.open("rb") as f:
+            chunk = f.read(_TEXT_PROBE_BYTES)
+    except OSError:
+        return "binary"
+    if b"\x00" in chunk:
+        return "binary"
+    try:
+        chunk.decode("utf-8")
+    except UnicodeDecodeError:
+        return "binary"
+    return "text"
+
+
+def max_inline_edit_bytes_cap(settings: DashboardSettings) -> int:
+    """Maximum bytes allowed for inline editor payloads from dashboard settings."""
+    n = settings.max_inline_edit_bytes
+    return n if n > 0 else DEFAULT_MAX_INLINE_BYTES
+
+
+def managed_paths_from_settings(
+    settings: DashboardSettings,
+    *,
+    home: Path,
+    hermes_home: Path,
+) -> list[Path]:
+    """Resolve the effective managed path set from personality refs plus additive config."""
+    canonical: list[Path] = []
+    seen: set[Path] = set()
+
+    for ref in settings.personality_files:
+        root = find_file_root(settings.file_roots, ref.root_id)
+        if root is None:
+            continue
+        try:
+            root_dir = resolve_root_directory(root, home=home, hermes_home=hermes_home)
+            target = resolve_under_root(root_dir, ref.path, home=home).resolve()
+        except (
+            AbsolutePathInRelativeError,
+            Fr33domBotExposureError,
+            PathOutsideRootError,
+            PathTraversalError,
+        ):
+            continue
+
+        if target not in seen:
+            seen.add(target)
+            canonical.append(target)
+
+    for p in settings.managed_paths:
+        expanded = expand_dashboard_path(p, home=home, hermes_home=hermes_home)
+        try:
+            target = expanded.resolve()
+        except OSError:
+            target = expanded
+
+        if target not in seen:
+            seen.add(target)
+            canonical.append(target)
+
+    return canonical
+
+
+def hidden_paths_from_settings(
+    settings: DashboardSettings,
+    *,
+    home: Path,
+    hermes_home: Path,
+) -> list[Path]:
+    """Resolve extra hidden paths that should stay out of the generic Files API."""
+    canonical: list[Path] = []
+    seen: set[Path] = set()
+
+    for p in settings.hidden_paths:
+        expanded = expand_dashboard_path(p, home=home, hermes_home=hermes_home)
+        try:
+            target = expanded.resolve()
+        except OSError:
+            target = expanded
+
+        if target not in seen:
+            seen.add(target)
+            canonical.append(target)
+
+    return canonical
+
+
+class ManagedPathTracker:
+    """Paths excluded from the generic Files API.
+
+    Includes both Personality-managed files and explicit hidden runtime
+    maintenance paths that should not appear in `/files`.
+    """
+
+    def __init__(
+        self,
+        paths: Iterable[Path | str],
+        *,
+        hidden_paths: Iterable[Path | str] = (),
+        home: Path,
+        hermes_home: Path,
+    ) -> None:
+        self._entries: list[tuple[Path, str]] = []
+        seen: set[Path] = set()
+
+        def register(items: Iterable[Path | str], detail: str) -> None:
+            for item in items:
+                if isinstance(item, Path):
+                    expanded = item
+                else:
+                    expanded = expand_dashboard_path(item, home=home, hermes_home=hermes_home)
+                try:
+                    resolved = expanded.resolve()
+                except OSError:
+                    resolved = expanded
+                if resolved in seen:
+                    continue
+                seen.add(resolved)
+                self._entries.append((resolved, detail))
+
+        register(paths, MANAGED_PATH_DETAIL)
+        register(hidden_paths, HIDDEN_PATH_DETAIL)
+
+    @classmethod
+    def from_settings(
+        cls,
+        settings: DashboardSettings,
+        *,
+        home: Path,
+        hermes_home: Path,
+    ) -> "ManagedPathTracker":
+        return cls(
+            managed_paths_from_settings(
+                settings,
+                home=home,
+                hermes_home=hermes_home,
+            ),
+            hidden_paths=hidden_paths_from_settings(
+                settings,
+                home=home,
+                hermes_home=hermes_home,
+            ),
+            home=home,
+            hermes_home=hermes_home,
+        )
+
+    def exclusion_detail(self, path: Path) -> str | None:
+        """Reason this path is blocked from the generic Files API, if any."""
+        try:
+            rp = path.resolve()
+        except OSError:
+            rp = path
+        for blocked, detail in self._entries:
+            if rp == blocked:
+                return detail
+            try:
+                rp.relative_to(blocked)
+                return detail
+            except ValueError:
+                continue
+        return None
+
+    def is_excluded_from_generic(self, path: Path) -> bool:
+        """True if this path should not appear in generic browse UI."""
+        return self.exclusion_detail(path) is not None
+
+    def ancestor_exclusion_detail(self, path: Path) -> str | None:
+        """Reason a strict descendant is excluded from the generic Files API, if any.
+
+        Used to block destructive operations (rename/delete) on directories that
+        contain a blocked file or directory, not only the blocked leaf itself.
+        """
+        try:
+            rp = path.resolve()
+        except OSError:
+            rp = path
+        for blocked, _detail in self._entries:
+            try:
+                if blocked.is_relative_to(rp) and blocked != rp:
+                    return _detail
+            except ValueError:
+                continue
+        return None
+
+    def is_ancestor_of_excluded_path(self, path: Path) -> bool:
+        """True if `path` is a strict directory ancestor of any excluded path."""
+        return self.ancestor_exclusion_detail(path) is not None
+
+    def is_ancestor_of_managed_path(self, path: Path) -> bool:
+        """Backward-compatible alias for ancestor checks in generic files flows."""
+        return self.is_ancestor_of_excluded_path(path)
