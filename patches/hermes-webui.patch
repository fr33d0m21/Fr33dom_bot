+        | { kind: 'revoke'; platform: string; userId: string }
+        | { kind: 'clear'; platform?: string },
+    ) => {
+      if (action.kind === 'approve') return api.approvePairing(action.platform, action.code)
+      if (action.kind === 'revoke') return api.revokePairing(action.platform, action.userId)
+      return api.clearPendingPairings(action.platform)
+    },
+    onSuccess: (result) => {
+      setNotice(result.message)
+      queryClient.invalidateQueries({ queryKey: ['pairing-state'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-status'] })
+    },
+    onError: (error) => {
+      setNotice(error instanceof Error ? error.message : 'Pairing action failed')
+    },
+  })
+
+  return (
+    <div
+      className="rounded-xl border p-5 space-y-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
+        <div>
+          <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+            Pairing Requests
+          </h3>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Approve or revoke messaging access without dropping into the CLI.
+          </p>
+        </div>
+        <div className="flex gap-2">
+          <Badge label="Pending" value={String(data?.pending.length || 0)} />
+          <Badge label="Approved" value={String(data?.approved.length || 0)} />
+        </div>
+      </div>
+
+      <div className="flex flex-wrap gap-3">
+        <button
+          onClick={() => mutatePairing.mutate({ kind: 'clear' })}
+          disabled={mutatePairing.isPending}
+          className="rounded-lg px-4 py-2 text-sm font-medium"
+          style={{ backgroundColor: 'var(--color-bg)', border: '1px solid var(--color-border)' }}
+        >
+          Clear pending
+        </button>
+        <span className="text-sm" style={{ color: notice ? 'var(--color-info)' : 'var(--color-text-muted)' }}>
+          {notice || 'Pending requests come from DM pairing flows on the gateway.'}
+        </span>
+      </div>
+
+      {isLoading ? (
+        <div className="text-sm" style={{ color: 'var(--color-text-muted)' }}>Loading pairing data...</div>
+      ) : (
+        <div className="grid gap-4 xl:grid-cols-2">
+          <section className="rounded-lg border p-4" style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)' }}>
+            <div className="flex items-center justify-between mb-3">
+              <h4 className="text-sm font-medium">Pending approvals</h4>
+              <span className="text-xs" style={{ color: 'var(--color-text-muted)' }}>
+                {data?.pending.length || 0} request(s)
+              </span>
+            </div>
+            <div className="space-y-3">
+              {data?.pending.length ? data.pending.map((item) => (
+                <div key={`${item.platform}-${item.code}`} className="rounded-lg border p-3" style={{ borderColor: 'var(--color-border)' }}>
+                  <div className="flex items-center justify-between gap-3">
+                    <div>
+                      <div className="font-medium text-sm">{item.user_name || item.user_id}</div>
+                      <div className="text-xs font-mono" style={{ color: 'var(--color-text-muted)' }}>
+                        {item.platform} · {item.code} · {item.age_minutes}m old
+                      </div>
+                    </div>
+                    <button
+                      onClick={() => mutatePairing.mutate({ kind: 'approve', platform: item.platform, code: item.code })}
+                      disabled={mutatePairing.isPending}
+                      className="rounded-lg px-3 py-1.5 text-sm font-medium"
+                      style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+                    >
+                      Approve
+                    </button>
+                  </div>
+                </div>
+              )) : (
+                <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>No pending pairing requests.</p>
+              )}
+            </div>
+          </section>
+
+          <section className="rounded-lg border p-4" style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)' }}>
+            <div className="flex items-center justify-between mb-3">
+              <h4 className="text-sm font-medium">Approved users</h4>
+              <span className="text-xs" style={{ color: 'var(--color-text-muted)' }}>
+                {data?.approved.length || 0} user(s)
+              </span>
+            </div>
+            <div className="space-y-3">
+              {data?.approved.length ? data.approved.map((item) => (
+                <div key={`${item.platform}-${item.user_id}`} className="rounded-lg border p-3" style={{ borderColor: 'var(--color-border)' }}>
+                  <div className="flex items-center justify-between gap-3">
+                    <div>
+                      <div className="font-medium text-sm">{item.user_name || item.user_id}</div>
+                      <div className="text-xs font-mono" style={{ color: 'var(--color-text-muted)' }}>
+                        {item.platform} · {item.user_id}
+                      </div>
+                    </div>
+                    <button
+                      onClick={() => mutatePairing.mutate({ kind: 'revoke', platform: item.platform, userId: item.user_id })}
+                      disabled={mutatePairing.isPending}
+                      className="rounded-lg px-3 py-1.5 text-sm font-medium"
+                      style={{ backgroundColor: 'rgba(255,107,143,0.12)', color: 'var(--color-error)' }}
+                    >
+                      Revoke
+                    </button>
+                  </div>
+                </div>
+              )) : (
+                <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>No approved pairing entries yet.</p>
+              )}
+            </div>
+          </section>
+        </div>
+      )}
+    </div>
+  )
+}
+
+function Badge({ label, value }: { label: string; value: string }) {
+  return (
+    <div className="rounded-lg px-3 py-2 text-sm" style={{ backgroundColor: 'var(--color-bg)' }}>
+      <div className="text-[11px] uppercase tracking-wide" style={{ color: 'var(--color-text-muted)' }}>
+        {label}
+      </div>
+      <div>{value}</div>
+    </div>
+  )
+}
diff --git a/frontend/src/components/admin/RuntimeControls.tsx b/frontend/src/components/admin/RuntimeControls.tsx
new file mode 100644
index 0000000..a8cec16
--- /dev/null
+++ b/frontend/src/components/admin/RuntimeControls.tsx
@@ -0,0 +1,132 @@
+import { useMutation, useQueryClient } from '@tanstack/react-query'
+import { useState } from 'react'
+import { api } from '../../api/client'
+import type { CommandActionResponse } from '../../api/types'
+
+function outputFor(result: CommandActionResponse | null): string {
+  if (!result) return ''
+  return [result.stdout?.trim(), result.stderr?.trim()].filter(Boolean).join('\n\n')
+}
+
+export function RuntimeControls({ gatewayRunning }: { gatewayRunning: boolean }) {
+  const queryClient = useQueryClient()
+  const [result, setResult] = useState<CommandActionResponse | null>(null)
+
+  const runAction = useMutation({
+    mutationFn: async (action: 'gatewayStart' | 'gatewayStop' | 'gatewayRestart' | 'doctor' | 'doctorFix') => {
+      if (action === 'gatewayStart') return api.adminGatewayStart()
+      if (action === 'gatewayStop') return api.adminGatewayStop()
+      if (action === 'gatewayRestart') return api.adminGatewayRestart()
+      if (action === 'doctorFix') return api.adminDoctor(true)
+      return api.adminDoctor(false)
+    },
+    onSuccess: (response) => {
+      setResult(response)
+      queryClient.invalidateQueries({ queryKey: ['gateway-status'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-config'] })
+    },
+    onError: (error) => {
+      setResult({
+        success: false,
+        action: 'error',
+        exit_code: 1,
+        stdout: '',
+        stderr: error instanceof Error ? error.message : 'Unknown action failure',
+      })
+    },
+  })
+
+  const busy = runAction.isPending
+  const output = outputFor(result)
+
+  return (
+    <div
+      className="rounded-xl border p-5 space-y-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex items-center justify-between gap-4">
+        <div>
+          <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+            Runtime Controls
+          </h3>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Start, stop, restart, or repair the runtime without leaving the dashboard.
+          </p>
+        </div>
+        <span
+          className="rounded-full px-3 py-1 text-xs font-medium"
+          style={{
+            backgroundColor: gatewayRunning ? 'rgba(43,253,28,0.12)' : 'rgba(255,107,143,0.12)',
+            color: gatewayRunning ? 'var(--color-success)' : 'var(--color-error)',
+          }}
+        >
+          Gateway {gatewayRunning ? 'running' : 'stopped'}
+        </span>
+      </div>
+
+      <div className="flex flex-wrap gap-3">
+        <ActionButton label="Start" onClick={() => runAction.mutate('gatewayStart')} disabled={busy} />
+        <ActionButton label="Stop" onClick={() => runAction.mutate('gatewayStop')} disabled={busy} />
+        <ActionButton label="Restart" onClick={() => runAction.mutate('gatewayRestart')} disabled={busy} />
+        <ActionButton label="Doctor" onClick={() => runAction.mutate('doctor')} disabled={busy} />
+        <ActionButton label="Doctor Fix" onClick={() => runAction.mutate('doctorFix')} disabled={busy} emphasis disabledStyle={busy} />
+      </div>
+
+      {result && (
+        <div className="space-y-3">
+          <div className="flex items-center gap-3 text-sm">
+            <span
+              className="font-medium"
+              style={{ color: result.success ? 'var(--color-success)' : 'var(--color-error)' }}
+            >
+              {result.success ? 'Success' : 'Failed'}
+            </span>
+            <span style={{ color: 'var(--color-text-muted)' }}>{result.action}</span>
+            <span className="font-mono text-xs" style={{ color: 'var(--color-text-muted)' }}>
+              exit {result.exit_code}
+            </span>
+          </div>
+
+          {output && (
+            <pre
+              className="rounded-lg p-3 text-xs whitespace-pre-wrap overflow-auto max-h-72"
+              style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+            >
+              {output}
+            </pre>
+          )}
+        </div>
+      )}
+    </div>
+  )
+}
+
+function ActionButton({
+  label,
+  onClick,
+  disabled,
+  emphasis,
+  disabledStyle,
+}: {
+  label: string
+  onClick: () => void
+  disabled?: boolean
+  emphasis?: boolean
+  disabledStyle?: boolean
+}) {
+  return (
+    <button
+      onClick={onClick}
+      disabled={disabled}
+      className="rounded-lg px-4 py-2 text-sm font-medium transition-opacity"
+      style={{
+        backgroundColor: emphasis ? 'var(--color-primary)' : 'var(--color-bg)',
+        color: emphasis ? '#041205' : 'var(--color-text)',
+        border: emphasis ? 'none' : '1px solid var(--color-border)',
+        opacity: disabledStyle ? 0.7 : 1,
+      }}
+    >
+      {label}
+    </button>
+  )
+}
