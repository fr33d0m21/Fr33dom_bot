+def _build_platform_response(platform: dict[str, Any], env_values: dict[str, str]) -> GatewayPlatformConfig:
+    configured, status = _is_platform_configured(platform["key"], env_values)
+    fields = []
+
+    for field in platform["fields"]:
+        raw_value = env_values.get(field["key"], "")
+        is_sensitive = bool(field.get("sensitive"))
+        fields.append(GatewayField(
+            key=field["key"],
+            label=field["label"],
+            value="" if is_sensitive else raw_value,
+            help=field.get("help", ""),
+            placeholder="Configured - leave blank to keep current value" if is_sensitive and raw_value else "",
+            input_type=field.get("input_type", "password" if is_sensitive else "text"),
+            configured=bool(raw_value),
+            sensitive=is_sensitive,
+            required=bool(field.get("required")),
+            options=field.get("options", []),
+        ))
+
+    return GatewayPlatformConfig(
+        key=platform["key"],
+        label=platform["label"],
+        emoji=platform.get("emoji", ""),
+        docs_url=platform.get("docs_url"),
+        configured=configured,
+        status=status,
+        description=platform.get("description", ""),
+        pairing_hint=platform.get("pairing_hint"),
+        fields=fields,
+    )
+
+
+def _missing_required_fields(platform: dict[str, Any], env_values: dict[str, str]) -> list[str]:
+    missing = []
+    for field in platform["fields"]:
+        if field.get("required") and not env_values.get(field["key"]):
+            missing.append(field["label"])
+    return missing
