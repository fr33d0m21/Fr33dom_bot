+"""Pydantic models for gateway configuration endpoints."""
+
+from typing import Any, Literal
+
+from pydantic import BaseModel, Field
+
+
+class GatewayField(BaseModel):
+    """Editable field for a single gateway platform."""
+
+    key: str
+    label: str
+    value: str = ""
+    help: str = ""
+    placeholder: str = ""
+    input_type: Literal["text", "password", "select"] = "text"
+    configured: bool = False
+    sensitive: bool = False
+    required: bool = False
+    options: list[str] = Field(default_factory=list)
+
+
+class GatewayPlatformConfig(BaseModel):
+    """Configuration metadata and current state for a platform."""
+
+    key: str
+    label: str
+    emoji: str = ""
+    docs_url: str | None = None
+    configured: bool = False
+    status: str = "not configured"
+    description: str = ""
+    pairing_hint: str | None = None
+    fields: list[GatewayField] = Field(default_factory=list)
+
+
+class GatewayConfigResponse(BaseModel):
