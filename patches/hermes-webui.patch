+import { screen, waitFor } from '@testing-library/react'
+import userEvent from '@testing-library/user-event'
+import { describe, expect, it, vi } from 'vitest'
+import { api } from '../../api/client'
+import { renderWithProviders } from '../../test/test-utils'
+import { RuntimeControls } from './RuntimeControls'
+
+describe('RuntimeControls', () => {
+  it('confirms before triggering a dashboard refresh action', async () => {
+    vi.spyOn(api, 'adminDashboardRefreshStatus').mockResolvedValue({
+      action: 'dashboard:refresh',
+      state: 'idle',
+      running: false,
+      pid: null,
+      exit_code: null,
+      started_at: null,
+      completed_at: null,
+      log: '',
+    })
+    const refreshSpy = vi.spyOn(api, 'adminDashboardRefresh').mockResolvedValue({
+      success: true,
+      action: 'dashboard:refresh',
+      exit_code: 0,
+      stdout: 'reset\nbuild\nrestart\n',
+      stderr: '',
+    })
+    const confirmSpy = vi.spyOn(window, 'confirm').mockImplementation((message?: string) => {
+      expect(message ?? '').toMatch(/refresh the dashboard/i)
+      expect(refreshSpy).not.toHaveBeenCalled()
+      return true
+    })
+    const user = userEvent.setup()
+
+    renderWithProviders(<RuntimeControls gatewayRunning />)
+
+    await user.click(screen.getByRole('button', { name: /refresh dashboard/i }))
+
+    expect(confirmSpy).toHaveBeenCalledTimes(1)
+    expect(refreshSpy).toHaveBeenCalledTimes(1)
+    await screen.findByText('dashboard:refresh')
+    await screen.findByText('Success')
+  })
+
+  it('does not call adminDashboardRefresh when the user cancels the refresh confirmation', async () => {
+    vi.spyOn(api, 'adminDashboardRefreshStatus').mockResolvedValue({
+      action: 'dashboard:refresh',
+      state: 'idle',
+      running: false,
+      pid: null,
+      exit_code: null,
+      started_at: null,
+      completed_at: null,
+      log: '',
+    })
+    const refreshSpy = vi.spyOn(api, 'adminDashboardRefresh').mockResolvedValue({
+      success: true,
+      action: 'dashboard:refresh',
+      exit_code: 0,
+      stdout: '',
+      stderr: '',
+    })
+    const confirmSpy = vi.spyOn(window, 'confirm').mockReturnValue(false)
+    const user = userEvent.setup()
+
+    renderWithProviders(<RuntimeControls gatewayRunning />)
+
+    await user.click(screen.getByRole('button', { name: /refresh dashboard/i }))
+
+    expect(confirmSpy).toHaveBeenCalledTimes(1)
+    expect(refreshSpy).not.toHaveBeenCalled()
+  })
+
+  it('polls dashboard refresh status and shows staged log output until completion', async () => {
+    const refreshSpy = vi.spyOn(api, 'adminDashboardRefresh').mockResolvedValue({
+      success: true,
+      action: 'dashboard:refresh',
+      exit_code: 0,
+      stdout: 'Scheduled dashboard refresh in the background (pid 43210).',
+      stderr: '',
+    })
+    const statusSpy = vi.spyOn(api, 'adminDashboardRefreshStatus')
+      .mockResolvedValueOnce({
+        action: 'dashboard:refresh',
+        state: 'idle',
+        running: false,
+        pid: null,
+        exit_code: null,
+        started_at: null,
+        completed_at: null,
+        log: '',
+      })
+      .mockResolvedValueOnce({
+        action: 'dashboard:refresh',
+        state: 'running',
+        running: true,
+        pid: 43210,
+        exit_code: null,
+        started_at: 1710000000,
+        completed_at: null,
+        log: '==> Validating local paths\n==> Applying Fr33dom patch\n',
+      })
+      .mockResolvedValueOnce({
+        action: 'dashboard:refresh',
+        state: 'running',
+        running: true,
+        pid: 43210,
+        exit_code: null,
+        started_at: 1710000000,
+        completed_at: null,
+        log: '==> Validating local paths\n==> Applying Fr33dom patch\n',
+      })
+      .mockResolvedValue({
+        action: 'dashboard:refresh',
+        state: 'success',
+        running: false,
+        pid: 43210,
+        exit_code: 0,
+        started_at: 1710000000,
+        completed_at: 1710000012,
+        log: '==> Validating local paths\n==> Dashboard refresh complete\n',
+      })
+    vi.spyOn(window, 'confirm').mockReturnValue(true)
+    const user = userEvent.setup()
+
+    renderWithProviders(<RuntimeControls gatewayRunning />)
+
+    await waitFor(() => {
+      expect(statusSpy).toHaveBeenCalledTimes(1)
+    })
+
+    await user.click(screen.getByRole('button', { name: /refresh dashboard/i }))
+
+    expect(refreshSpy).toHaveBeenCalledTimes(1)
+    expect(await screen.findByText(/applying fr33dom patch/i)).toBeInTheDocument()
+    expect(await screen.findByText(/dashboard refresh complete/i, {}, { timeout: 2500 })).toBeInTheDocument()
+  })
+})
diff --git a/frontend/src/components/admin/RuntimeControls.tsx b/frontend/src/components/admin/RuntimeControls.tsx
new file mode 100644
index 0000000..8a6ba09
--- /dev/null
+++ b/frontend/src/components/admin/RuntimeControls.tsx
@@ -0,0 +1,205 @@
+import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query'
+import { useState } from 'react'
+import { api } from '../../api/client'
+import type { CommandActionResponse, DashboardRefreshStatusResponse } from '../../api/types'
+
+function outputFor(result: CommandActionResponse | null): string {
+  if (!result) return ''
+  return [result.stdout?.trim(), result.stderr?.trim()].filter(Boolean).join('\n\n')
+}
+
+function refreshStatusLabel(status: DashboardRefreshStatusResponse | null): string {
+  if (!status) return ''
+  if (status.state === 'running') return 'Running'
+  if (status.state === 'success') return 'Success'
+  if (status.state === 'failure') return 'Failed'
+  return 'Idle'
+}
+
+function refreshStatusColor(status: DashboardRefreshStatusResponse | null): string {
+  if (!status) return 'var(--color-text-muted)'
+  if (status.state === 'running') return 'var(--color-info)'
+  if (status.state === 'success') return 'var(--color-success)'
+  if (status.state === 'failure') return 'var(--color-error)'
+  return 'var(--color-text-muted)'
+}
+
+export function RuntimeControls({ gatewayRunning }: { gatewayRunning: boolean }) {
+  const queryClient = useQueryClient()
+  const [result, setResult] = useState<CommandActionResponse | null>(null)
+  const refreshStatusQuery = useQuery({
+    queryKey: ['dashboard-refresh-status'],
+    queryFn: api.adminDashboardRefreshStatus,
+    refetchInterval: (query) => (query.state.data?.running ? 1000 : false),
+  })
+  const refreshStatus = refreshStatusQuery.data ?? null
+  const refreshOutput = refreshStatus?.log.trim() ?? ''
+  const showRefreshStatus = refreshStatus !== null && refreshStatus.state !== 'idle'
+
+  const runAction = useMutation({
+    mutationFn: async (
+      action: 'gatewayStart' | 'gatewayStop' | 'gatewayRestart' | 'dashboardRefresh' | 'doctor' | 'doctorFix',
+    ) => {
+      if (action === 'gatewayStart') return api.adminGatewayStart()
+      if (action === 'gatewayStop') return api.adminGatewayStop()
+      if (action === 'gatewayRestart') return api.adminGatewayRestart()
+      if (action === 'dashboardRefresh') return api.adminDashboardRefresh()
+      if (action === 'doctorFix') return api.adminDoctor(true)
+      return api.adminDoctor(false)
+    },
+    onSuccess: (response, action) => {
+      setResult(response)
+      if (action === 'dashboardRefresh') {
+        void queryClient.invalidateQueries({ queryKey: ['dashboard-refresh-status'] })
+        void queryClient.invalidateQueries()
+        return
+      }
+      queryClient.invalidateQueries({ queryKey: ['gateway-status'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-config'] })
+    },
+    onError: (error) => {
+      setResult({
+        success: false,
+        action: 'error',
+        exit_code: 1,
+        stdout: '',
+        stderr: error instanceof Error ? error.message : 'Unknown action failure',
+      })
+    },
+  })
+
+  const busy = runAction.isPending
+  const output = outputFor(result)
+  const handleDashboardRefresh = () => {
+    const confirmed = window.confirm(
+      'Refresh the dashboard now? This will run the local refresh script and may take a minute or two.',
+    )
+    if (!confirmed) return
+    runAction.mutate('dashboardRefresh')
+  }
+
+  return (
+    <div
+      className="rounded-xl border p-5 space-y-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex items-center justify-between gap-4">
+        <div>
+          <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+            Runtime Controls
+          </h3>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Start, stop, restart, refresh, or repair the runtime without leaving the dashboard.
+          </p>
+        </div>
+        <span
+          className="rounded-full px-3 py-1 text-xs font-medium"
+          style={{
+            backgroundColor: gatewayRunning ? 'rgba(43,253,28,0.12)' : 'rgba(255,107,143,0.12)',
+            color: gatewayRunning ? 'var(--color-success)' : 'var(--color-error)',
+          }}
+        >
+          Gateway {gatewayRunning ? 'running' : 'stopped'}
+        </span>
+      </div>
+
+      <div className="flex flex-wrap gap-3">
+        <ActionButton label="Start" onClick={() => runAction.mutate('gatewayStart')} disabled={busy} />
+        <ActionButton label="Stop" onClick={() => runAction.mutate('gatewayStop')} disabled={busy} />
+        <ActionButton label="Restart" onClick={() => runAction.mutate('gatewayRestart')} disabled={busy} />
+        <ActionButton label="Refresh Dashboard" onClick={handleDashboardRefresh} disabled={busy} />
+        <ActionButton label="Doctor" onClick={() => runAction.mutate('doctor')} disabled={busy} />
+        <ActionButton label="Doctor Fix" onClick={() => runAction.mutate('doctorFix')} disabled={busy} emphasis disabledStyle={busy} />
+      </div>
+
+      {showRefreshStatus && (
+        <div className="space-y-3">
+          <div className="flex items-center gap-3 text-sm">
+            <span
+              className="font-medium"
+              style={{ color: refreshStatusColor(refreshStatus) }}
+            >
+              {refreshStatusLabel(refreshStatus)}
+            </span>
+            <span style={{ color: 'var(--color-text-muted)' }}>{refreshStatus?.action}</span>
+            {refreshStatus?.pid !== null && (
+              <span className="font-mono text-xs" style={{ color: 'var(--color-text-muted)' }}>
+                pid {refreshStatus.pid}
+              </span>
+            )}
+            {refreshStatus?.exit_code !== null && (
+              <span className="font-mono text-xs" style={{ color: 'var(--color-text-muted)' }}>
+                exit {refreshStatus.exit_code}
+              </span>
+            )}
+          </div>
+
+          {refreshOutput && (
+            <pre
+              className="rounded-lg p-3 text-xs whitespace-pre-wrap overflow-auto max-h-72"
+              style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+            >
+              {refreshOutput}
+            </pre>
+          )}
+        </div>
+      )}
+
+      {result && (!showRefreshStatus || result.action !== 'dashboard:refresh') && (
+        <div className="space-y-3">
+          <div className="flex items-center gap-3 text-sm">
+            <span
+              className="font-medium"
+              style={{ color: result.success ? 'var(--color-success)' : 'var(--color-error)' }}
+            >
+              {result.success ? 'Success' : 'Failed'}
+            </span>
+            <span style={{ color: 'var(--color-text-muted)' }}>{result.action}</span>
+            <span className="font-mono text-xs" style={{ color: 'var(--color-text-muted)' }}>
+              exit {result.exit_code}
+            </span>
+          </div>
+
+          {output && (
+            <pre
+              className="rounded-lg p-3 text-xs whitespace-pre-wrap overflow-auto max-h-72"
+              style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+            >
+              {output}
+            </pre>
+          )}
+        </div>
+      )}
+    </div>
+  )
+}
+
+function ActionButton({
+  label,
+  onClick,
+  disabled,
+  emphasis,
+  disabledStyle,
+}: {
+  label: string
+  onClick: () => void
+  disabled?: boolean
+  emphasis?: boolean
+  disabledStyle?: boolean
+}) {
+  return (
+    <button
+      onClick={onClick}
+      disabled={disabled}
+      className="rounded-lg px-4 py-2 text-sm font-medium transition-opacity"
+      style={{
+        backgroundColor: emphasis ? 'var(--color-primary)' : 'var(--color-bg)',
+        color: emphasis ? '#041205' : 'var(--color-text)',
+        border: emphasis ? 'none' : '1px solid var(--color-border)',
+        opacity: disabledStyle ? 0.7 : 1,
+      }}
+    >
+      {label}
+    </button>
+  )
+}
