@@ -0,0 +1,351 @@
+"""Gateway configuration endpoints."""
+
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Any
+
+import httpx
+from fastapi import APIRouter, Depends, HTTPException
+
+from webui.auth import require_auth
+from webui.hermes_bridge import HERMES_HOME, get_env_path, read_config_yaml, write_config_yaml_value
+from webui.schemas.gateway_config import (
+    GatewayConfigPatchResponse,
+    GatewayConfigResponse,
+    GatewayField,
+    GatewayPlatformConfig,
+    GatewayPlatformPatchRequest,
+    GatewayTestResponse,
+)
+
+router = APIRouter(prefix="/api/gateway", tags=["gateway"], dependencies=[Depends(require_auth)])
+
+_DOCS_BASE = "https://hermes-agent.nousresearch.com/docs/user-guide/messaging"
+
+_PLATFORM_SPECS: list[dict[str, Any]] = [
+    {
+        "key": "telegram",
+        "label": "Telegram",
+        "emoji": "📱",
+        "description": "BotFather token, allowed users, and optional home chat for cron delivery.",
+        "docs_url": f"{_DOCS_BASE}/telegram",
+        "fields": [
+            {"key": "TELEGRAM_BOT_TOKEN", "label": "Bot token", "help": "Telegram bot token from @BotFather.", "sensitive": True, "required": True},
+            {"key": "TELEGRAM_ALLOWED_USERS", "label": "Allowed user IDs", "help": "Comma-separated Telegram user IDs.", "required": False},
+            {"key": "TELEGRAM_HOME_CHANNEL", "label": "Home channel", "help": "Chat ID for cron delivery (optional).", "required": False},
+        ],
+    },
+    {
+        "key": "discord",
+        "label": "Discord",
+        "emoji": "💬",
+        "description": "Discord bot token, trusted user IDs, and optional home channel.",
+        "docs_url": f"{_DOCS_BASE}/discord",
+        "fields": [
+            {"key": "DISCORD_BOT_TOKEN", "label": "Bot token", "help": "Discord bot token from the Developer Portal.", "sensitive": True, "required": True},
+            {"key": "DISCORD_ALLOWED_USERS", "label": "Allowed user IDs", "help": "Comma-separated Discord member IDs.", "required": False},
+            {"key": "DISCORD_HOME_CHANNEL", "label": "Home channel", "help": "Channel ID for cron delivery (optional).", "required": False},
+            {"key": "DISCORD_REQUIRE_MENTION", "label": "Require mention", "help": "Set false to allow free-response channels.", "required": False},
+            {"key": "DISCORD_FREE_RESPONSE_CHANNELS", "label": "Free-response channels", "help": "Comma-separated channel IDs where @mention is not required.", "required": False},
+        ],
+    },
+    {
+        "key": "slack",
+        "label": "Slack",
+        "emoji": "💼",
+        "description": "Socket Mode tokens plus allowed users and optional home channel.",
+        "docs_url": f"{_DOCS_BASE}/slack",
