+
+    if (treeResult.error) {
+      setNotice({
+        tone: 'error',
+        text: loadFailureMessage(treeResult.error, 'Failed to refresh the current folder.'),
+      })
+      return
+    }
+
+    if (selectedPath) {
+      const fileResult = await contentQuery.refetch()
+      if (fileResult.error) {
+        setNotice({
+          tone: 'error',
+          text: loadFailureMessage(fileResult.error, 'Failed to reload the selected file.'),
+        })
