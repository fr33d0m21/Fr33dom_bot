diff --git a/frontend/src/pages/Personality.test.tsx b/frontend/src/pages/Personality.test.tsx
new file mode 100644
index 0000000..d76fc60
--- /dev/null
+++ b/frontend/src/pages/Personality.test.tsx
@@ -0,0 +1,172 @@
+import { afterEach, describe, expect, it, vi } from 'vitest'
+import { screen } from '@testing-library/react'
+import userEvent from '@testing-library/user-event'
+import App from '../App'
+import { api } from '../api/client'
+import type { PersonalityDetailResponse, PersonalitySummary } from '../api/types'
+import { renderWithProviders } from '../test/test-utils'
+import { Personality } from './Personality'
+
+vi.mock('../hooks/useWebSocket', () => ({
+  useWebSocket: () => ({
+    connected: true,
+    events: [],
+    subscribe: () => () => undefined,
+  }),
+}))
+
+describe('Personality route', () => {
+  afterEach(() => {
+    vi.restoreAllMocks()
+    sessionStorage.clear()
+  })
+
+  function buildSummary(overrides: Partial<PersonalitySummary> = {}): PersonalitySummary {
+    return {
+      id: 'curated',
+      label: 'Curated',
+      root_id: 'runtime',
+      path: 'personality/curated.md',
+      resolved_path: '/runtime/personality/curated.md',
+      exists: true,
+      revision: 'rev-1',
+      size: 128,
+      kind: 'text',
+      ...overrides,
+    }
+  }
+
+  function buildDetail(overrides: Partial<PersonalityDetailResponse> = {}): PersonalityDetailResponse {
+    return {
+      ...buildSummary(overrides),
+      content: '',
+      ...overrides,
+    }
+  }
+
+  it('loads the first curated personality entry and shows its content', async () => {
+    sessionStorage.setItem('hermes_webui_token', 'test-token')
+
+    vi.spyOn(api, 'health').mockResolvedValue({
+      status: 'ok',
+      version: 'test',
+    })
+
+    const entry = {
+      id: 'curated',
+      label: 'Curated',
+      root_id: 'runtime',
+      path: 'personality/curated.md',
+      resolved_path: '/runtime/personality/curated.md',
+      exists: true,
+      revision: 'rev-1',
+      size: 128,
+      kind: 'text',
+    }
+
+    const detailSpy = vi.spyOn(api, 'personalityDetail').mockResolvedValue({
+      ...entry,
+      content: 'You are the curated system prompt.',
+    })
+
+    vi.spyOn(api, 'personalityList').mockResolvedValue({
+      entries: [entry],
+    })
+
+    renderWithProviders(<App />, { route: '/personality' })
+
+    expect(await screen.findByRole('heading', { name: 'Curated' })).toBeInTheDocument()
+    expect(await screen.findByDisplayValue('You are the curated system prompt.')).toBeInTheDocument()
+    expect(detailSpy).toHaveBeenCalledWith('curated')
+  })
+
+  it('shows the missing curated file state while keeping the editor editable', async () => {
+    const user = userEvent.setup()
+    const missingEntry = buildDetail({
+      exists: false,
+      revision: '0',
+      size: null,
+      kind: null,
+      content: '',
+    })
+
+    vi.spyOn(api, 'personalityList').mockResolvedValue({
+      entries: [missingEntry],
+    })
+    vi.spyOn(api, 'personalityDetail').mockResolvedValue(missingEntry)
+
+    renderWithProviders(<Personality />)
+
+    expect(await screen.findByText(/missing on disk/i)).toBeInTheDocument()
+
+    const editor = screen.getByRole('textbox', { name: /personality content/i })
+    await user.type(editor, '# Curated file created from the dashboard')
+
+    expect(screen.getByRole('button', { name: /^save$/i })).toBeEnabled()
+  })
+
+  it('reloads the latest content after a stale revision save conflict', async () => {
+    const user = userEvent.setup()
+    const initialDetail = {
+      ...buildDetail(),
+      content: 'Original curated content',
+    }
+    const reloadedDetail = {
+      ...buildDetail({
+        revision: 'rev-2',
+        size: 144,
+      }),
+      content: 'Updated on disk by another editor',
+    }
+
+    const detailSpy = vi.spyOn(api, 'personalityDetail')
+      .mockResolvedValueOnce(initialDetail)
+      .mockResolvedValueOnce(reloadedDetail)
+
+    vi.spyOn(api, 'personalityList').mockResolvedValue({
+      entries: [buildSummary()],
+    })
+    const updateSpy = vi.spyOn(api, 'updatePersonality').mockRejectedValue(
+      new Error('API error 409: {"detail":"Stale revision"}'),
+    )
+
+    renderWithProviders(<Personality />)
+
+    const editor = await screen.findByRole('textbox', { name: /personality content/i })
+    await user.clear(editor)
+    await user.type(editor, 'Local unsaved draft')
+    await user.click(screen.getByRole('button', { name: /^save$/i }))
+
+    expect(updateSpy).toHaveBeenCalledWith('curated', {
+      content: 'Local unsaved draft',
+      revision: 'rev-1',
+    })
+    expect(await screen.findByText(/changed on disk/i)).toBeInTheDocument()
+
+    await user.click(screen.getByRole('button', { name: /reload/i }))
+
+    await screen.findByText(/reloaded the latest file contents/i)
+    expect(screen.getByRole('textbox', { name: /personality content/i })).toHaveValue(
+      'Updated on disk by another editor',
+    )
+    expect(detailSpy).toHaveBeenCalledTimes(2)
+  })
+
+  it('opens Files at the containing folder for managed personality files', async () => {
+    vi.spyOn(api, 'personalityList').mockResolvedValue({
+      entries: [buildSummary()],
+    })
+    vi.spyOn(api, 'personalityDetail').mockResolvedValue(
+      buildDetail({
+        content: '# Curated file\n',
+      }),
+    )
+
+    renderWithProviders(<Personality />)
+
+    expect(await screen.findByRole('link', { name: /open in files/i })).toHaveAttribute(
+      'href',
+      '/files?root=runtime&folder=personality',
+    )
+  })
+})
diff --git a/frontend/src/pages/Personality.tsx b/frontend/src/pages/Personality.tsx
