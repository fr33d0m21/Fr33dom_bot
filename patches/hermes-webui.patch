+import type { PersonalitySummary } from '../../api/types'
+import { entryTitle } from './labels'
+
+interface PersonalityEntryListProps {
+  entries: PersonalitySummary[]
+  selectedId: string | null
+  isLoading?: boolean
+  errorMessage?: string | null
+  onSelect: (id: string) => void
+}
+
+function entryState(entry: PersonalitySummary): string {
+  if (!entry.exists) return 'Missing'
+  if (entry.kind === 'binary') return 'Binary'
+  return 'Ready'
+}
+
+export function PersonalityEntryList({
+  entries,
+  selectedId,
+  isLoading = false,
+  errorMessage = null,
+  onSelect,
+}: PersonalityEntryListProps) {
+  return (
+    <aside
+      className="rounded-xl border p-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="mb-4 space-y-1">
+        <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+          Curated Files
+        </h3>
+        <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+          Choose which curated personality file to inspect or edit.
+        </p>
+      </div>
+
+      {isLoading && (
+        <div className="rounded-lg border border-dashed p-4 text-sm" style={{ borderColor: 'var(--color-border)', color: 'var(--color-text-muted)' }}>
+          Loading curated personality files...
+        </div>
+      )}
+
+      {!isLoading && errorMessage && (
+        <div className="rounded-lg border border-dashed p-4 text-sm" style={{ borderColor: 'var(--color-border)', color: 'var(--color-error)' }}>
+          {errorMessage}
+        </div>
+      )}
+
+      {!isLoading && !errorMessage && entries.length === 0 && (
+        <div className="rounded-lg border border-dashed p-4 text-sm" style={{ borderColor: 'var(--color-border)', color: 'var(--color-text-muted)' }}>
+          No curated personality files are configured.
+        </div>
+      )}
+
+      {!isLoading && !errorMessage && entries.length > 0 && (
+        <div className="space-y-2">
+          {entries.map((entry) => {
+            const active = entry.id === selectedId
+            return (
+              <button
+                key={entry.id}
+                type="button"
+                onClick={() => onSelect(entry.id)}
+                className="w-full rounded-lg border p-3 text-left transition-colors"
+                style={{
+                  borderColor: active ? 'var(--color-primary)' : 'var(--color-border)',
+                  backgroundColor: active ? 'rgba(99,102,241,0.12)' : 'var(--color-bg)',
+                  color: 'var(--color-text)',
+                }}
+              >
+                <div className="flex items-start justify-between gap-3">
+                  <div className="min-w-0">
+                    <div className="font-medium text-sm truncate">{entryTitle(entry)}</div>
+                    <div className="mt-1 text-xs font-mono break-all" style={{ color: 'var(--color-text-muted)' }}>
+                      {entry.path}
+                    </div>
+                  </div>
+                  <span
+                    className="rounded-full px-2 py-0.5 text-[10px] font-medium whitespace-nowrap"
+                    style={{
+                      backgroundColor: entry.exists ? 'rgba(34,197,94,0.12)' : 'rgba(245,158,11,0.12)',
+                      color: entry.exists ? 'var(--color-success)' : 'var(--color-warning)',
+                    }}
+                  >
+                    {entryState(entry)}
+                  </span>
+                </div>
+              </button>
+            )
+          })}
+        </div>
+      )}
+    </aside>
+  )
+}
