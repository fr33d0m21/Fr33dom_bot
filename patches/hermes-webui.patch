@@ -0,0 +1,117 @@
+"""Tests for admin action endpoints."""
+
+import json
+import subprocess
+from unittest.mock import patch
+
+from webui.routers.admin_actions import _run_local_command
+
+
+def test_run_local_command_timeout_returns_structured_response():
+    """Timeout becomes a CommandActionResponse instead of an uncaught exception."""
+    with patch(
+        "webui.routers.admin_actions.subprocess.run",
+        side_effect=subprocess.TimeoutExpired(
+            cmd=["/dummy"],
+            timeout=5,
+            output="partial out\n",
+            stderr="partial err\n",
+        ),
+    ):
+        resp = _run_local_command("test:action", ["/dummy"], timeout=5)
+
+    assert resp.success is False
+    assert resp.action == "test:action"
+    assert resp.exit_code == 124
+    assert resp.stdout == "partial out\n"
+    assert "Command timed out after 5s" in resp.stderr
+    assert "partial err" in resp.stderr
+
+
+def test_run_local_command_timeout_without_partial_output():
+    with patch(
+        "webui.routers.admin_actions.subprocess.run",
+        side_effect=subprocess.TimeoutExpired(cmd=["/dummy"], timeout=2),
+    ):
+        resp = _run_local_command("slow:action", ["/dummy"], timeout=2)
+
+    assert resp.success is False
+    assert resp.exit_code == 124
+    assert resp.stdout == ""
+    assert resp.stderr == "Command timed out after 2s"
+
+
+def test_dashboard_refresh_starts_local_script_detached(client, fake_user_home, temp_hermes_home):
+    """Dashboard refresh returns before the service restart can interrupt the request."""
+    script_path = fake_user_home / ".local" / "bin" / "fr33d0m-refresh-dashboard"
+    script_path.parent.mkdir(parents=True, exist_ok=True)
+    script_path.write_text("#!/usr/bin/env bash\n", encoding="utf-8")
+    script_path.chmod(0o755)
+    log_path = temp_hermes_home / "logs" / "dashboard-refresh.log"
+
+    with patch("webui.routers.admin_actions.Path.home", return_value=fake_user_home), patch(
+        "webui.routers.admin_actions.HERMES_HOME", temp_hermes_home
+    ), patch(
+        "webui.routers.admin_actions.subprocess.Popen"
+    ) as mock_popen:
+        mock_popen.return_value.pid = 43210
+        response = client.post("/api/admin/dashboard/refresh")
+        status_response = client.get("/api/admin/dashboard/refresh/status")
+
+    assert response.status_code == 200
+    assert response.json()["success"] is True
+    assert response.json()["action"] == "dashboard:refresh"
+    assert response.json()["exit_code"] == 0
+    assert "Scheduled dashboard refresh" in response.json()["stdout"]
+    assert str(log_path) in response.json()["stdout"]
+    assert response.json()["stderr"] == ""
+
+    assert status_response.status_code == 200
+    assert status_response.json()["state"] == "running"
+    assert status_response.json()["running"] is True
+    assert status_response.json()["pid"] == 43210
+    assert "Dashboard refresh requested from WebUI" in status_response.json()["log"]
+
+    mock_popen.assert_called_once()
+    assert mock_popen.call_args.args[0] == [str(script_path)]
+    assert mock_popen.call_args.kwargs["stdin"] == subprocess.DEVNULL
+    assert mock_popen.call_args.kwargs["stderr"] == subprocess.STDOUT
+    assert mock_popen.call_args.kwargs["start_new_session"] is True
+    assert mock_popen.call_args.kwargs["close_fds"] is True
+    assert mock_popen.call_args.kwargs["stdout"].name == str(log_path)
+    assert mock_popen.call_args.kwargs["env"]["HERMES_HOME"] == str(temp_hermes_home)
+    assert log_path.is_file()
+
+
+def test_dashboard_refresh_status_returns_completed_log_output(client, temp_hermes_home):
+    log_dir = temp_hermes_home / "logs"
+    log_dir.mkdir(parents=True, exist_ok=True)
+    log_path = log_dir / "dashboard-refresh.log"
+    status_path = log_dir / "dashboard-refresh.status.json"
+
+    log_path.write_text(
+        "\n==> Validating local paths\n==> Dashboard refresh complete\n",
+        encoding="utf-8",
+    )
+    status_path.write_text(
+        json.dumps(
+            {
+                "state": "success",
+                "pid": 43210,
+                "exit_code": 0,
+                "started_at": 1710000000.0,
+                "completed_at": 1710000015.0,
+            }
+        ),
+        encoding="utf-8",
+    )
+
+    with patch("webui.routers.admin_actions.HERMES_HOME", temp_hermes_home):
+        response = client.get("/api/admin/dashboard/refresh/status")
+
+    assert response.status_code == 200
+    data = response.json()
+    assert data["state"] == "success"
+    assert data["running"] is False
+    assert data["exit_code"] == 0
+    assert "Dashboard refresh complete" in data["log"]
