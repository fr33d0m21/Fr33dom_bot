diff --git a/webui/dashboard_settings.py b/webui/dashboard_settings.py
new file mode 100644
index 0000000..98006ff
--- /dev/null
+++ b/webui/dashboard_settings.py
@@ -0,0 +1,53 @@
+"""Load runtime dashboard settings from ~/.hermes/fr33d0m-dashboard.yaml."""
+
+import os
+from pathlib import Path
+
+import yaml
+from pydantic import BaseModel, Field
+
+HERMES_HOME = Path(os.getenv("HERMES_HOME", Path.home() / ".hermes"))
+DASHBOARD_SETTINGS_FILE = "fr33d0m-dashboard.yaml"
+DEFAULT_MAX_INLINE_EDIT_BYTES = 1_000_000
+
+
+class FileRoot(BaseModel):
+    """A browsable filesystem root exposed in the dashboard."""
+
+    id: str
+    label: str | None = None
+    path: str
+
+
+class PersonalityFileRef(BaseModel):
+    """Personality-managed file bound to a root (for dedicated editors)."""
+
+    id: str
+    label: str | None = None
+    root_id: str
+    path: str
+
+
+class DashboardSettings(BaseModel):
+    """Runtime dashboard configuration for file roots and inline editing."""
+
+    file_roots: list[FileRoot] = Field(default_factory=list)
+    personality_files: list[PersonalityFileRef] = Field(default_factory=list)
+    managed_paths: list[str] = Field(default_factory=list)
+    hidden_paths: list[str] = Field(default_factory=list)
+    max_inline_edit_bytes: int = DEFAULT_MAX_INLINE_EDIT_BYTES
+
+
+def load_dashboard_settings(hermes_home: Path | None = None) -> DashboardSettings:
+    """Load dashboard YAML from HERMES_HOME, or return empty defaults if missing."""
+    base = hermes_home or HERMES_HOME
+    path = base / DASHBOARD_SETTINGS_FILE
+    if not path.is_file():
+        return DashboardSettings()
+    try:
+        raw = yaml.safe_load(path.read_text(encoding="utf-8"))
+    except (OSError, yaml.YAMLError):
+        return DashboardSettings()
+    if raw is None or not isinstance(raw, dict):
+        return DashboardSettings()
+    return DashboardSettings.model_validate(raw)
diff --git a/webui/routers/admin_actions.py b/webui/routers/admin_actions.py
new file mode 100644
index 0000000..91c73fe
--- /dev/null
+++ b/webui/routers/admin_actions.py
@@ -0,0 +1,404 @@
+"""Allowlisted admin action endpoints for the dashboard."""
+
+from __future__ import annotations
+
+import json
+import os
+import shutil
+import subprocess
+import time
+from pathlib import Path
+
+from fastapi import APIRouter, Depends, HTTPException
+
+from webui.auth import require_auth
+from webui.hermes_bridge import HERMES_HOME, init_hermes_path
+from webui.schemas.admin_actions import (
+    CommandActionResponse,
+    DashboardRefreshStatusResponse,
+    DoctorActionRequest,
+    PairingApproveRequest,
+    PairingClearRequest,
+    PairingMutationResponse,
+    PairingRevokeRequest,
+    PairingStateResponse,
+)
+
+router = APIRouter(prefix="/api/admin", tags=["admin"], dependencies=[Depends(require_auth)])
+
+
+def _runtime_env() -> dict[str, str]:
+    env = os.environ.copy()
+    env["HERMES_HOME"] = str(HERMES_HOME)
+
+    local_bin = str(Path.home() / ".local" / "bin")
+    env["PATH"] = ":".join([local_bin, "/usr/local/bin", "/usr/bin", "/bin", env.get("PATH", "")])
+
+    runtime_dir = Path(f"/run/user/{os.getuid()}")
+    if runtime_dir.exists():
+        env["XDG_RUNTIME_DIR"] = str(runtime_dir)
+        bus_path = runtime_dir / "bus"
+        if bus_path.exists():
+            env["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={bus_path}"
+
+    return env
+
+
+def _captured_stream_text(data: bytes | str | None) -> str:
+    if data is None:
+        return ""
+    if isinstance(data, str):
+        return data
+    if isinstance(data, bytes):
+        return data.decode(errors="replace")
+    return str(data)
+
+
+def _cli_command() -> str:
+    for candidate in (
+        shutil.which("fr33d0m"),
+        str(Path.home() / ".local" / "bin" / "fr33d0m"),
+        shutil.which("hermes"),
+    ):
+        if candidate and Path(candidate).exists():
+            return candidate
+    raise HTTPException(status_code=500, detail="Could not locate fr33d0m/hermes CLI")
+
+
+def _preferred_gateway_service_name() -> str | None:
+    runtime_home = Path.home()
+    custom_unit = runtime_home / ".config" / "systemd" / "user" / "fr33d0m-gateway.service"
+    default_unit = runtime_home / ".config" / "systemd" / "user" / "hermes-gateway.service"
+    if custom_unit.exists():
+        return "fr33d0m-gateway.service"
+    if default_unit.exists():
+        return "hermes-gateway.service"
+    return None
+
+
+def _run_local_command(action: str, cmd: list[str], timeout: int = 180) -> CommandActionResponse:
+    try:
+        result = subprocess.run(
+            cmd,
+            capture_output=True,
+            text=True,
+            env=_runtime_env(),
+            timeout=timeout,
+        )
+    except subprocess.TimeoutExpired as exc:
+        raw_out = getattr(exc, "output", None) or getattr(exc, "stdout", None)
+        stdout = _captured_stream_text(raw_out)
+        stderr = _captured_stream_text(exc.stderr)
+        detail = f"Command timed out after {exc.timeout}s"
+        merged_stderr = f"{detail}\n{stderr}".strip() if stderr else detail
+        return CommandActionResponse(
+            success=False,
+            action=action,
+            exit_code=124,
+            stdout=stdout,
+            stderr=merged_stderr,
+        )
+    return CommandActionResponse(
+        success=result.returncode == 0,
+        action=action,
+        exit_code=result.returncode,
+        stdout=result.stdout,
+        stderr=result.stderr,
+    )
+
+
+def _run_cli(action: str, args: list[str], timeout: int = 180) -> CommandActionResponse:
+    return _run_local_command(action, [_cli_command(), *args], timeout=timeout)
+
+
+def _dashboard_refresh_script() -> str:
+    script_path = Path.home() / ".local" / "bin" / "fr33d0m-refresh-dashboard"
+    if script_path.is_file() and os.access(script_path, os.X_OK):
+        return str(script_path)
+    raise HTTPException(status_code=500, detail="Could not locate local dashboard refresh script")
+
+
+def _dashboard_refresh_log_path() -> Path:
+    log_dir = HERMES_HOME / "logs"
+    log_dir.mkdir(parents=True, exist_ok=True)
+    return log_dir / "dashboard-refresh.log"
+
+
+def _dashboard_refresh_status_path() -> Path:
+    log_dir = HERMES_HOME / "logs"
+    log_dir.mkdir(parents=True, exist_ok=True)
+    return log_dir / "dashboard-refresh.status.json"
+
+
+def _write_dashboard_refresh_status(
+    *,
+    state: str,
+    pid: int | None,
+    exit_code: int | None,
+    started_at: float | None,
+    completed_at: float | None,
+) -> None:
+    status_path = _dashboard_refresh_status_path()
+    status_path.write_text(
+        json.dumps(
+            {
+                "state": state,
+                "pid": pid,
+                "exit_code": exit_code,
+                "started_at": started_at,
+                "completed_at": completed_at,
+            }
+        ),
+        encoding="utf-8",
+    )
+
+
+def _read_dashboard_refresh_status_payload() -> dict[str, object]:
+    status_path = _dashboard_refresh_status_path()
+    if not status_path.is_file():
+        return {}
+    try:
+        raw = json.loads(status_path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError):
+        return {}
+    if isinstance(raw, dict):
+        return raw
+    return {}
+
+
+def _coerce_int(value: object) -> int | None:
+    if isinstance(value, bool):
+        return None
+    if isinstance(value, int):
+        return value
+    if isinstance(value, float):
+        return int(value)
+    return None
+
+
+def _coerce_float(value: object) -> float | None:
+    if isinstance(value, bool):
+        return None
+    if isinstance(value, (int, float)):
+        return float(value)
+    return None
+
+
+def _dashboard_refresh_process_running(pid: int | None) -> bool:
+    if pid is None or pid <= 0:
+        return False
+    try:
+        os.kill(pid, 0)
+    except OSError:
+        return False
+    return True
+
+
+def _dashboard_refresh_state_from_log(log_text: str) -> tuple[str, int | None]:
+    if "==> Dashboard refresh complete" in log_text:
+        return "success", 0
+    if "ERROR:" in log_text or "Traceback" in log_text:
+        return "failure", 1
+    normalized = log_text.strip()
+    if normalized and "Waiting for detached refresh process to start..." not in normalized:
+        return "failure", 1
+    return "running", None
+
+
+def _dashboard_refresh_status() -> DashboardRefreshStatusResponse:
+    payload = _read_dashboard_refresh_status_payload()
+    log_path = _dashboard_refresh_log_path()
+    try:
+        log_text = log_path.read_text(encoding="utf-8", errors="replace")
+    except OSError:
+        log_text = ""
+
+    state = str(payload.get("state", "idle"))
+    pid = _coerce_int(payload.get("pid"))
+    exit_code = _coerce_int(payload.get("exit_code"))
+    started_at = _coerce_float(payload.get("started_at"))
+    completed_at = _coerce_float(payload.get("completed_at"))
+
+    if state == "running" and not _dashboard_refresh_process_running(pid):
+        next_state, inferred_exit_code = _dashboard_refresh_state_from_log(log_text)
+        if next_state != "running":
+            state = next_state
+            exit_code = exit_code if exit_code is not None else inferred_exit_code
+            if completed_at is None and log_path.exists():
+                completed_at = log_path.stat().st_mtime
+            _write_dashboard_refresh_status(
+                state=state,
+                pid=pid,
+                exit_code=exit_code,
+                started_at=started_at,
+                completed_at=completed_at,
+            )
+
+    if state not in {"idle", "running", "success", "failure"}:
+        state = "idle"
+
+    return DashboardRefreshStatusResponse(
+        state=state,
+        running=state == "running",
+        pid=pid,
+        exit_code=exit_code,
+        started_at=started_at,
+        completed_at=completed_at,
+        log=log_text,
+    )
+
+
+def _schedule_dashboard_refresh() -> CommandActionResponse:
+    script = _dashboard_refresh_script()
+    log_path = _dashboard_refresh_log_path()
+    started_at = time.time()
+
+    try:
+        log_path.write_text("\n==> Dashboard refresh requested from WebUI\n", encoding="utf-8")
+        with log_path.open("a", encoding="utf-8") as log_handle:
+            log_handle.write("Waiting for detached refresh process to start...\n")
+            log_handle.flush()
+            process = subprocess.Popen(
+                [script],
+                stdin=subprocess.DEVNULL,
+                stdout=log_handle,
+                stderr=subprocess.STDOUT,
+                env=_runtime_env(),
+                start_new_session=True,
+                close_fds=True,
+            )
+    except OSError as exc:
+        _write_dashboard_refresh_status(
+            state="failure",
+            pid=None,
+            exit_code=1,
+            started_at=started_at,
+            completed_at=time.time(),
+        )
+        with log_path.open("a", encoding="utf-8") as log_handle:
+            log_handle.write(f"ERROR: Failed to start dashboard refresh: {exc}\n")
+        return CommandActionResponse(
+            success=False,
+            action="dashboard:refresh",
+            exit_code=1,
+            stdout="",
+            stderr=f"Failed to start dashboard refresh: {exc}",
+        )
+
+    _write_dashboard_refresh_status(
+        state="running",
+        pid=process.pid,
+        exit_code=None,
+        started_at=started_at,
+        completed_at=None,
+    )
+
+    return CommandActionResponse(
+        success=True,
+        action="dashboard:refresh",
+        exit_code=0,
+        stdout=(
+            f"Scheduled dashboard refresh in the background (pid {process.pid}).\n"
+            f"Follow progress in {log_path}.\n"
+            "The dashboard service will restart separately after the refresh completes."
+        ),
+        stderr="",
+    )
+
+
+def _run_gateway_service(action: str) -> CommandActionResponse:
+    service_name = _preferred_gateway_service_name()
+    if not service_name:
+        return _run_cli(f"gateway:{action}", ["gateway", action])
+
+    return _run_local_command(
+        f"gateway:{action}",
+        ["systemctl", "--user", action, service_name],
+        timeout=120,
+    )
+
+
+def _pairing_store():
+    init_hermes_path()
+    from gateway.pairing import PairingStore
+
+    return PairingStore()
+
+
+@router.post("/gateway/start", response_model=CommandActionResponse)
+async def gateway_start() -> CommandActionResponse:
+    return _run_gateway_service("start")
+
+
+@router.post("/gateway/stop", response_model=CommandActionResponse)
+async def gateway_stop() -> CommandActionResponse:
+    return _run_gateway_service("stop")
+
+
+@router.post("/gateway/restart", response_model=CommandActionResponse)
+async def gateway_restart() -> CommandActionResponse:
+    return _run_gateway_service("restart")
+
+
+@router.post("/doctor", response_model=CommandActionResponse)
+async def doctor_action(req: DoctorActionRequest) -> CommandActionResponse:
+    args = ["doctor"]
+    action = "doctor"
+    if req.fix:
+        args.append("--fix")
+        action = "doctor:fix"
+    return _run_cli(action, args, timeout=240)
+
+
+@router.post("/dashboard/refresh", response_model=CommandActionResponse)
+async def dashboard_refresh() -> CommandActionResponse:
+    return _schedule_dashboard_refresh()
+
+
+@router.get("/dashboard/refresh/status", response_model=DashboardRefreshStatusResponse)
+async def dashboard_refresh_status() -> DashboardRefreshStatusResponse:
+    return _dashboard_refresh_status()
+
+
+@router.get("/pairing", response_model=PairingStateResponse)
+async def pairing_state() -> PairingStateResponse:
+    store = _pairing_store()
+    return PairingStateResponse(
+        pending=store.list_pending(),
+        approved=store.list_approved(),
+    )
+
+
+@router.post("/pairing/approve", response_model=PairingMutationResponse)
+async def pairing_approve(req: PairingApproveRequest) -> PairingMutationResponse:
+    store = _pairing_store()
+    result = store.approve_code(req.platform, req.code)
+    if not result:
+        raise HTTPException(status_code=404, detail="Pairing code not found or expired")
+    return PairingMutationResponse(
+        success=True,
+        message=f"Approved {result['user_name'] or result['user_id']} on {req.platform}",
+    )
+
+
+@router.post("/pairing/revoke", response_model=PairingMutationResponse)
+async def pairing_revoke(req: PairingRevokeRequest) -> PairingMutationResponse:
+    store = _pairing_store()
+    removed = store.revoke(req.platform, req.user_id)
+    if not removed:
+        raise HTTPException(status_code=404, detail="Approved user not found")
+    return PairingMutationResponse(
+        success=True,
+        message=f"Revoked {req.user_id} on {req.platform}",
+    )
+
+
+@router.post("/pairing/clear-pending", response_model=PairingMutationResponse)
+async def pairing_clear_pending(req: PairingClearRequest) -> PairingMutationResponse:
+    store = _pairing_store()
+    removed = store.clear_pending(req.platform)
+    label = req.platform or "all platforms"
+    return PairingMutationResponse(
+        success=True,
+        message=f"Cleared {removed} pending pairing request(s) for {label}",
+    )
