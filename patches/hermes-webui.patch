@@ -0,0 +1,126 @@
+"""Tests for personality editor API (curated files, revision-aware saves)."""
+
+
+def test_list_personality_curated_entries(client):
+    """GET /api/personality lists curated personality_files from dashboard settings."""
+    response = client.get("/api/personality")
+    assert response.status_code == 200
+    data = response.json()
+    assert "entries" in data
+    entries = data["entries"]
+    assert len(entries) >= 1
+    soul = next(e for e in entries if e["id"] == "soul")
+    assert soul["label"] == "SOUL"
+    assert soul["root_id"] == "hermes-home"
+    assert soul["path"] == "SOUL.md"
+    assert soul["exists"] is True
+    assert "revision" in soul
+    assert soul["revision"].isdigit()
+    assert "resolved_path" in soul
+    assert "kind" in soul
+
+
+def test_get_personality_detail(client, temp_hermes_home):
+    """GET /api/personality/{id} returns content and revision."""
+    response = client.get("/api/personality/soul")
+    assert response.status_code == 200
+    data = response.json()
+    assert data["id"] == "soul"
+    assert "SOUL" in data["content"] or "personality" in data["content"].lower()
+    assert data["exists"] is True
+    assert data["revision"].isdigit()
+    assert data["path"] == "SOUL.md"
+    assert "resolved_path" in data
+    assert data["kind"] == "text"
+
+
+def test_get_personality_invalid_utf8_without_nul_returns_binary_style_response(client, temp_hermes_home):
+    """GET does not crash on non-UTF-8 files without NUL bytes; it reports them as binary."""
+    soul = temp_hermes_home / "SOUL.md"
+    payload = b"\x80not-utf8-but-no-nul"
+    soul.write_bytes(payload)
+
+    response = client.get("/api/personality/soul")
+    assert response.status_code == 200
+    data = response.json()
+    assert data["kind"] == "binary"
+    assert data["content"] == ""
+    assert data["size"] == len(payload)
+
+
+def test_get_personality_unknown_returns_404(client):
+    """GET /api/personality/{id} returns 404 for unknown ids."""
+    response = client.get("/api/personality/does-not-exist")
+    assert response.status_code == 404
+
+
+def test_put_personality_saves_with_revision_check(client, temp_hermes_home):
+    """PUT /api/personality/{id} writes content when revision matches."""
+    r = client.get("/api/personality/soul")
+    assert r.status_code == 200
+    rev = r.json()["revision"]
+    new_content = "# SOUL\n\nUpdated personality body.\n"
+    r2 = client.put(
+        "/api/personality/soul",
+        json={"content": new_content, "revision": rev},
+    )
+    assert r2.status_code == 200
+    out = r2.json()
+    assert out["revision"] != rev
+    assert (temp_hermes_home / "SOUL.md").read_text(encoding="utf-8") == new_content
+
+
+def test_put_personality_stale_revision_returns_409(client, temp_hermes_home):
+    """PUT returns 409 when revision no longer matches the file on disk."""
+    r = client.get("/api/personality/soul")
+    assert r.status_code == 200
+    stale_rev = r.json()["revision"]
+    (temp_hermes_home / "SOUL.md").write_text("# changed externally\n", encoding="utf-8")
+    r2 = client.put(
+        "/api/personality/soul",
+        json={"content": "should not apply", "revision": stale_rev},
+    )
+    assert r2.status_code == 409
+    assert (temp_hermes_home / "SOUL.md").read_text(encoding="utf-8") == "# changed externally\n"
+
+
+def test_put_personality_unknown_returns_404(client):
+    """PUT returns 404 for unknown personality id."""
+    r = client.put(
+        "/api/personality/unknown-id",
+        json={"content": "x", "revision": "0"},
+    )
+    assert r.status_code == 404
+
+
+def test_put_personality_rejects_binary_file(client, temp_hermes_home):
+    """PUT refuses to replace a file that probes as binary (e.g. NUL in content)."""
+    soul = temp_hermes_home / "SOUL.md"
+    binary_payload = b"not\x00utf8-text"
+    soul.write_bytes(binary_payload)
+    r = client.get("/api/personality/soul")
+    assert r.status_code == 200
+    assert r.json()["kind"] == "binary"
+    rev = r.json()["revision"]
+    r2 = client.put(
+        "/api/personality/soul",
+        json={"content": "plain text replacement", "revision": rev},
+    )
+    assert r2.status_code == 415
+    assert soul.read_bytes() == binary_payload
+
+
+def test_put_personality_rejects_invalid_utf8_without_nul_file(client, temp_hermes_home):
+    """PUT refuses to replace a non-UTF-8 file even when it contains no NUL bytes."""
+    soul = temp_hermes_home / "SOUL.md"
+    binary_payload = b"\x80still-not-utf8"
+    soul.write_bytes(binary_payload)
+    revision = str(soul.stat().st_mtime_ns)
+
+    response = client.put(
+        "/api/personality/soul",
+        json={"content": "plain text replacement", "revision": revision},
+    )
+
+    assert response.status_code == 415
+    assert soul.read_bytes() == binary_payload
