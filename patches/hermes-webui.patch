+def _safe_custom_skill_dir(dir_name: str, category: str = "") -> tuple[Path, str, str | None]:
+    base = get_custom_skills_dir().resolve()
+    safe_dir = _slugify_skill_name(dir_name)
+    safe_category = _slugify_skill_name(category) if category else ""
+    if not safe_dir:
