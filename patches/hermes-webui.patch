+
+      setNotice({ tone: 'success', text: 'Deleted the selected entry.' })
+    },
+    onError: (error) => {
+      const parsed = parseApiError(error)
+      setNotice({
+        tone: 'error',
+        text: parsed.detail || 'Failed to delete the selected entry.',
+      })
+    },
+  })
+
+  const handleRootChange = (nextRootId: string) => {
+    setNotice(null)
+    setSearchParams(buildFilesSearchParams({ root: nextRootId }), { replace: true })
+  }
+
+  const handleNavigate = (nextPath: string) => {
+    setNotice(null)
+    if (!activeRootId) return
+    setSearchParams(buildFilesSearchParams({ root: activeRootId, folder: nextPath }), { replace: true })
+  }
+
+  const handleSelectFile = (path: string) => {
+    setNotice(null)
+    if (!activeRootId) return
+    setSearchParams(buildFilesSearchParams({ root: activeRootId, path }), { replace: true })
+  }
+
+  const handleRefresh = async () => {
+    setNotice(null)
