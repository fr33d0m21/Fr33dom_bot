+"""Pydantic models for dashboard action endpoints."""
+
+from __future__ import annotations
+
+from typing import Literal
+
+from pydantic import BaseModel, Field
+
+
+class CommandActionResponse(BaseModel):
+    """Result of running an allowlisted admin command."""
+
+    success: bool
+    action: str
+    exit_code: int
+    stdout: str = ""
+    stderr: str = ""
+
+
+class DoctorActionRequest(BaseModel):
+    """Request to run doctor or doctor --fix."""
+
+    fix: bool = False
+
+
+class PairingPendingEntry(BaseModel):
+    """Pending pairing request."""
+
+    platform: str
+    code: str
+    user_id: str
+    user_name: str = ""
+    age_minutes: int = 0
+
+
+class PairingApprovedEntry(BaseModel):
+    """Approved pairing entry."""
+
+    platform: str
+    user_id: str
+    user_name: str = ""
+    approved_at: float
+
+
+class PairingStateResponse(BaseModel):
+    """Pending and approved pairing state."""
+
+    pending: list[PairingPendingEntry] = Field(default_factory=list)
+    approved: list[PairingApprovedEntry] = Field(default_factory=list)
+
+
+class PairingApproveRequest(BaseModel):
+    """Approve a pairing code."""
+
+    platform: str
+    code: str
+
+
+class PairingRevokeRequest(BaseModel):
+    """Revoke a paired user."""
+
+    platform: str
+    user_id: str
+
+
+class PairingMutationResponse(BaseModel):
+    """Pairing mutation result."""
+
+    success: bool
+    message: str
+
+
+class PairingClearRequest(BaseModel):
+    """Clear pending pairings for one or all platforms."""
+
+    platform: str | None = None
+
+
+class ServiceActionRequest(BaseModel):
+    """Lifecycle action for a service."""
+
+    action: Literal["start", "stop", "restart"]
