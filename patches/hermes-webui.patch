+
+  const contentError = contentQuery.error ? parseApiError(contentQuery.error) : null
+  const selectedExactPath = activeContent?.resolved_path || (selectedPath ? buildExactPath(currentRoot, selectedPath) : '')
+
+  return (
+    <div className="p-6 flex flex-col gap-6 md:h-full">
