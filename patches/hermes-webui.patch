+    stderr: str = ""
+
+
+class DashboardRefreshStatusResponse(BaseModel):
+    """Detached dashboard refresh status plus the current combined log output."""
+
+    action: Literal["dashboard:refresh"] = "dashboard:refresh"
+    state: Literal["idle", "running", "success", "failure"] = "idle"
+    running: bool = False
+    pid: int | None = None
+    exit_code: int | None = None
+    started_at: float | None = None
+    completed_at: float | None = None
