+    }
+
+    uploadMutation.mutate({
+      rootId: activeRootId,
+      path: currentPath,
+      file,
+    })
+  }
+
+  const handleCreateFolder = () => {
+    if (!activeRootId) return
+
+    const value = window.prompt('Enter a folder name or relative path to create under the current directory.')
