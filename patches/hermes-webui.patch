+import { afterEach, describe, expect, it, vi } from 'vitest'
+import { QueryClientProvider } from '@tanstack/react-query'
+import { render, screen, waitFor } from '@testing-library/react'
+import userEvent from '@testing-library/user-event'
+import { MemoryRouter, Route, Routes, useLocation, useNavigate } from 'react-router-dom'
+import App from '../App'
+import { api } from '../api/client'
+import type { FileContentResponse, FileEntry, FileRootSummary } from '../api/types'
+import { createTestQueryClient, renderWithProviders } from '../test/test-utils'
+import { Files } from './Files'
+
+vi.mock('../hooks/useWebSocket', () => ({
+  useWebSocket: () => ({
+    connected: true,
+    events: [],
+    subscribe: () => () => undefined,
+  }),
+}))
+
+function buildRoot(overrides: Partial<FileRootSummary> = {}): FileRootSummary {
+  return {
+    id: 'runtime',
+    label: 'Runtime',
+    path: '~/runtime',
+    resolved_path: '/runtime',
+    ...overrides,
+  }
+}
+
+function buildEntry(overrides: Partial<FileEntry> = {}): FileEntry {
+  return {
+    name: 'curated.md',
+    path: 'personality/curated.md',
+    is_dir: false,
+    size: 128,
+    revision: 'rev-1',
+    kind: 'text',
+    mime_type: 'text/markdown',
+    content_type: 'text/markdown',
+    is_image: false,
+    ...overrides,
+  }
+}
+
+function buildContent(overrides: Partial<FileContentResponse> = {}): FileContentResponse {
+  return {
+    root_id: 'runtime',
+    path: 'personality/curated.md',
+    resolved_path: '/runtime/personality/curated.md',
+    name: 'curated.md',
+    size: 128,
+    revision: 'rev-1',
+    kind: 'text',
+    mime_type: 'text/markdown',
+    content_type: 'text/markdown',
+    is_image: false,
+    inline_editable: true,
+    too_large: false,
+    content: '# Curated file\n',
+    ...overrides,
+  }
+}
+
+describe('Files route', () => {
+  afterEach(() => {
+    sessionStorage.clear()
+    vi.restoreAllMocks()
+  })
+
+  it('loads the requested file from query params and saves inline text edits', async () => {
+    const user = userEvent.setup()
+
+    sessionStorage.setItem('hermes_webui_token', 'test-token')
+
+    vi.spyOn(api, 'health').mockResolvedValue({
+      status: 'ok',
+      version: 'test',
+    })
+
+    const rootsSpy = vi.spyOn(api, 'fileRoots').mockResolvedValue({
+      roots: [
+        buildRoot(),
+        buildRoot({
+          id: 'downloads',
+          label: 'Downloads',
+          path: '~/Downloads',
+          resolved_path: '/Users/test/Downloads',
+        }),
+      ],
+    })
+
+    const treeSpy = vi.spyOn(api, 'fileTree').mockImplementation(async (rootId, path = '') => ({
+      root_id: rootId,
+      path,
+      entries: [
+        buildEntry(),
+        buildEntry({
+          name: 'notes.txt',
+          path: 'personality/notes.txt',
+          size: 64,
+          mime_type: 'text/plain',
+          content_type: 'text/plain',
+        }),
+      ],
+    }))
+
+    const contentSpy = vi.spyOn(api, 'fileContent').mockResolvedValue(
+      buildContent({
+        content: '# Curated file\nLoaded from query params.\n',
+      }),
+    )
+
+    const updateSpy = vi.spyOn(api, 'updateFileContent').mockResolvedValue({
+      path: 'personality/curated.md',
+      revision: 'rev-2',
+      size: 43,
+    })
+
+    renderWithProviders(<App />, { route: '/files?root=runtime&path=personality/curated.md' })
+
+    expect(await screen.findByRole('link', { name: /^files$/i })).toBeInTheDocument()
+    expect(await screen.findByRole('heading', { name: /^files$/i })).toBeInTheDocument()
+    const editor = await screen.findByRole('textbox', { name: /file content/i })
+    expect(editor).toHaveValue('# Curated file\nLoaded from query params.\n')
+    expect(await screen.findByText('/runtime/personality/curated.md')).toBeInTheDocument()
+
+    expect(rootsSpy).toHaveBeenCalledTimes(1)
+    expect(treeSpy).toHaveBeenCalledWith('runtime', 'personality')
+    expect(contentSpy).toHaveBeenCalledWith('runtime', 'personality/curated.md')
+
+    await user.clear(editor)
+    await user.type(editor, '# Curated file\nSaved from the Files page.\n')
+    await user.click(screen.getByRole('button', { name: /^save$/i }))
+
+    await waitFor(() => {
+      expect(updateSpy).toHaveBeenCalledWith({
+        root_id: 'runtime',
+        path: 'personality/curated.md',
+        revision: 'rev-1',
+        content: '# Curated file\nSaved from the Files page.\n',
+      })
+    })
+
+    expect(await screen.findByText(/saved file changes/i)).toBeInTheDocument()
+  })
+
+  it('shows the backend-resolved exact path instead of rebuilding it from the URL selection', async () => {
+    sessionStorage.setItem('hermes_webui_token', 'test-token')
+
+    vi.spyOn(api, 'health').mockResolvedValue({
+      status: 'ok',
+      version: 'test',
+    })
+    vi.spyOn(api, 'fileRoots').mockResolvedValue({
+      roots: [
+        buildRoot({
+          resolved_path: '/Users/test/runtime',
+        }),
+      ],
+    })
+    vi.spyOn(api, 'fileTree').mockResolvedValue({
+      root_id: 'runtime',
+      path: 'links',
+      entries: [
+        buildEntry({
+          name: 'current.txt',
+          path: 'links/current.txt',
+          size: 64,
+          mime_type: 'text/plain',
+          content_type: 'text/plain',
+        }),
+      ],
+    })
+    vi.spyOn(api, 'fileContent').mockResolvedValue(
+      {
+        ...buildContent({
+          path: 'targets/actual.txt',
+          name: 'actual.txt',
+          mime_type: 'text/plain',
+          content_type: 'text/plain',
+          content: 'hello through symlink\n',
+        }),
+        resolved_path: '/Users/test/runtime/targets/actual.txt',
+      } as FileContentResponse,
+    )
+
+    renderWithProviders(<App />, { route: '/files?root=runtime&path=links/current.txt' })
+
+    expect(await screen.findByText('/Users/test/runtime/targets/actual.txt')).toBeInTheDocument()
+    expect(screen.queryByText('/Users/test/runtime/links/current.txt')).not.toBeInTheDocument()
+  })
+
+  it('replaces a symlink request with the backend canonical path before saving', async () => {
+    const user = userEvent.setup()
+
+    sessionStorage.setItem('hermes_webui_token', 'test-token')
+
+    vi.spyOn(api, 'health').mockResolvedValue({
+      status: 'ok',
+      version: 'test',
+    })
+    vi.spyOn(api, 'fileRoots').mockResolvedValue({
+      roots: [
+        buildRoot({
+          resolved_path: '/Users/test/runtime',
+        }),
+      ],
+    })
+    const treeSpy = vi.spyOn(api, 'fileTree').mockImplementation(async (rootId, path = '') => ({
+      root_id: rootId,
+      path,
+      entries: [
+        buildEntry({
+          name: path === 'targets' ? 'actual.txt' : 'current.txt',
+          path: path === 'targets' ? 'targets/actual.txt' : 'links/current.txt',
+          size: 64,
+          mime_type: 'text/plain',
+          content_type: 'text/plain',
+        }),
+      ],
+    }))
+    const contentSpy = vi.spyOn(api, 'fileContent').mockResolvedValue(
+      {
+        ...buildContent({
+          path: 'targets/actual.txt',
+          name: 'actual.txt',
+          mime_type: 'text/plain',
+          content_type: 'text/plain',
