+def _read_env_values() -> dict[str, str]:
+    env_path = get_env_path()
+    if not env_path.exists():
+        return {}
+
+    values: dict[str, str] = {}
+    for line in env_path.read_text(encoding="utf-8").splitlines():
+        line = line.strip()
+        if not line or line.startswith("#") or "=" not in line:
+            continue
+        key, _, value = line.partition("=")
+        values[key.strip()] = value.strip().strip('"').strip("'")
+    return values
+
+
+def _set_env_value(key: str, value: str) -> None:
+    env_path = get_env_path()
+    env_path.parent.mkdir(parents=True, exist_ok=True)
+    if not env_path.exists():
+        env_path.write_text("", encoding="utf-8")
+
+    from dotenv import set_key
+
+    set_key(str(env_path), key, value)
+
+
+def _is_platform_configured(platform_key: str, env_values: dict[str, str]) -> tuple[bool, str]:
+    if platform_key == "telegram":
+        configured = bool(env_values.get("TELEGRAM_BOT_TOKEN"))
+        return configured, "configured" if configured else "not configured"
+
+    if platform_key == "discord":
+        configured = bool(env_values.get("DISCORD_BOT_TOKEN"))
+        return configured, "configured" if configured else "not configured"
+
+    if platform_key == "slack":
+        configured = bool(env_values.get("SLACK_BOT_TOKEN") and env_values.get("SLACK_APP_TOKEN"))
+        return configured, "configured" if configured else "partially configured" if env_values.get("SLACK_BOT_TOKEN") or env_values.get("SLACK_APP_TOKEN") else "not configured"
+
+    if platform_key == "whatsapp":
+        enabled = env_values.get("WHATSAPP_ENABLED", "").lower() == "true"
+        session_file = HERMES_HOME / "whatsapp" / "session" / "creds.json"
+        if enabled and session_file.exists():
+            return True, "configured + paired"
+        if enabled:
+            return False, "enabled, waiting for QR pairing"
+        return False, "not configured"
+
+    if platform_key == "signal":
+        configured = bool(env_values.get("SIGNAL_HTTP_URL") and env_values.get("SIGNAL_ACCOUNT"))
+        return configured, "configured" if configured else "partially configured" if env_values.get("SIGNAL_HTTP_URL") or env_values.get("SIGNAL_ACCOUNT") else "not configured"
+
+    if platform_key == "email":
+        parts = [
+            env_values.get("EMAIL_ADDRESS"),
+            env_values.get("EMAIL_PASSWORD"),
+            env_values.get("EMAIL_IMAP_HOST"),
+            env_values.get("EMAIL_SMTP_HOST"),
+        ]
+        configured = all(parts)
+        return configured, "configured" if configured else "partially configured" if any(parts) else "not configured"
+
+    return False, "not configured"
+
