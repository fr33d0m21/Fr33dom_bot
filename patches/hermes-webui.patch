+"""Allowlisted generic file browsing and mutation endpoints."""
+
+from __future__ import annotations
+
+import mimetypes
+import shutil
+from pathlib import Path
+
+from fastapi import APIRouter, Depends, File, Form, HTTPException, Query, UploadFile
+from fastapi.responses import FileResponse
+
+from webui import hermes_bridge
+from webui.auth import require_auth
+from webui.dashboard_settings import DashboardSettings, FileRoot, load_dashboard_settings
+from webui.runtime_fs import (
+    AbsolutePathInRelativeError,
+    Fr33domBotExposureError,
+    ManagedPathTracker,
+    PathOutsideRootError,
+    PathTraversalError,
+    find_file_root,
+    first_symlink_alias,
+    max_inline_edit_bytes_cap,
+    resolve_root_directory,
+    resolve_under_root,
+    revision_token,
+    text_binary_probe,
+)
+from webui.schemas.files import (
+    FileContentResponse,
+    FileContentUpdateRequest,
+    FileContentUpdateResponse,
+    FileDeleteResponse,
+    FileEntry,
+    FileFolderCreateRequest,
+    FileFolderCreateResponse,
+    FileRenameRequest,
+    FileRenameResponse,
+    FileRootSummary,
+    FileRootsResponse,
+    FileTreeResponse,
+    FileUploadResponse,
+)
+
+UPLOAD_MAX_BYTES = 50 * 1024 * 1024
+
+router = APIRouter(prefix="/api/files", tags=["files"], dependencies=[Depends(require_auth)])
+
+
+def _hermes_home() -> Path:
+    return hermes_bridge.HERMES_HOME
+
+
+def _home() -> Path:
+    hermes_home = _hermes_home()
+    if hermes_home.name == ".hermes":
+        return hermes_home.parent
+    return Path.home()
+
+
+def _load_settings() -> DashboardSettings:
+    return load_dashboard_settings(hermes_home=_hermes_home())
+
+
+def _blocked_tracker(settings: DashboardSettings) -> ManagedPathTracker:
+    return ManagedPathTracker.from_settings(
+        settings,
+        home=_home(),
+        hermes_home=_hermes_home(),
+    )
+
+
+def _reject_if_blocked_directory_ancestor(settings: DashboardSettings, path: Path) -> None:
+    """Block rename/delete on a directory that contains a blocked descendant."""
+    detail = _blocked_tracker(settings).ancestor_exclusion_detail(path)
+    if detail is not None:
+        raise HTTPException(
+            status_code=403,
+            detail=detail,
+        )
+
+
+def _reject_if_symlink_alias(root_dir: Path, relative: str, *, action: str) -> None:
+    """Block destructive mutation requests that route through a symlink alias path."""
+    if first_symlink_alias(root_dir, relative) is None:
+        return
+    raise HTTPException(
+        status_code=409,
+        detail=f"Refusing to {action} via a symlink alias path; open the resolved target directly instead",
+    )
+
+
+def _resolve_root(settings: DashboardSettings, root_id: str) -> tuple[FileRoot, Path]:
+    root = find_file_root(settings.file_roots, root_id)
+    if root is None:
+        raise HTTPException(status_code=404, detail="File root not found")
+    try:
+        root_dir = resolve_root_directory(root, home=_home(), hermes_home=_hermes_home())
+    except Fr33domBotExposureError as exc:
+        raise HTTPException(status_code=403, detail="Configured root is not allowed") from exc
+    detail = _blocked_tracker(settings).exclusion_detail(root_dir)
+    if detail is not None:
+        raise HTTPException(status_code=403, detail=detail)
+    return root, root_dir
+
+
+def _resolve_target(
+    settings: DashboardSettings,
+    root_id: str,
+    relative: str,
+    *,
+    allow_root: bool = False,
+) -> tuple[Path, Path, str]:
+    _root, root_dir = _resolve_root(settings, root_id)
+    try:
+        target = resolve_under_root(root_dir, relative, home=_home())
+    except PathTraversalError as exc:
+        raise HTTPException(status_code=400, detail="Path traversal is not allowed") from exc
+    except AbsolutePathInRelativeError as exc:
+        raise HTTPException(status_code=400, detail="Absolute paths are not allowed") from exc
+    except PathOutsideRootError as exc:
+        raise HTTPException(status_code=400, detail="Path escapes the selected root") from exc
+    except Fr33domBotExposureError as exc:
+        raise HTTPException(status_code=403, detail="Path is not allowed") from exc
+
+    rel = "" if target == root_dir else target.relative_to(root_dir).as_posix()
+    if not allow_root and not rel:
+        raise HTTPException(status_code=400, detail="Path is required")
+
+    detail = _blocked_tracker(settings).exclusion_detail(target)
+    if detail is not None:
+        raise HTTPException(
+            status_code=403,
+            detail=detail,
+        )
+
+    return root_dir, target, rel
+
+
+def _mime_type(path: Path) -> str | None:
+    mime_type, _encoding = mimetypes.guess_type(path.name)
+    return mime_type
+
+
+def _is_image_mime(mime_type: str | None) -> bool:
+    return bool(mime_type and mime_type.startswith("image/"))
+
+
+def _entry_from_path(root_dir: Path, path: Path) -> FileEntry:
+    rel = path.relative_to(root_dir).as_posix()
+    is_symlink = path.is_symlink()
+    if path.is_dir():
+        return FileEntry(
+            name=path.name,
+            path=rel,
+            is_dir=True,
+            is_symlink=is_symlink,
+            kind="directory",
+        )
+
+    mime_type = _mime_type(path)
+    return FileEntry(
+        name=path.name,
+        path=rel,
+        is_dir=False,
+        is_symlink=is_symlink,
+        size=path.stat().st_size,
+        revision=revision_token(path),
+        kind=text_binary_probe(path),
+        mime_type=mime_type,
+        is_image=_is_image_mime(mime_type),
+    )
+
+
+def _content_response(
+    root_id: str,
+    rel: str,
+    path: Path,
+    *,
+    inline_cap: int,
+) -> FileContentResponse:
+    size = path.stat().st_size
+    mime_type = _mime_type(path)
+    kind = text_binary_probe(path)
+    too_large = size > inline_cap
+    inline_editable = False
+    content: str | None = None
+
+    if kind == "text" and not too_large:
+        try:
+            content = path.read_text(encoding="utf-8")
+        except UnicodeDecodeError:
+            kind = "binary"
+        else:
+            inline_editable = True
+
+    return FileContentResponse(
+        root_id=root_id,
+        path=rel,
+        resolved_path=str(path),
+        name=path.name,
+        size=size,
+        revision=revision_token(path),
+        kind=kind,
+        mime_type=mime_type,
+        is_image=_is_image_mime(mime_type),
+        inline_editable=inline_editable,
+        too_large=too_large,
+        content=content,
+    )
+
+
+@router.get("/roots", response_model=FileRootsResponse)
+async def list_roots() -> FileRootsResponse:
+    """List configured generic file roots."""
+    settings = _load_settings()
+    tracker = _blocked_tracker(settings)
+    roots: list[FileRootSummary] = []
+    for root in settings.file_roots:
+        try:
+            resolved = resolve_root_directory(root, home=_home(), hermes_home=_hermes_home())
+        except Fr33domBotExposureError:
+            continue
+        if tracker.exclusion_detail(resolved) is not None:
+            continue
+        roots.append(
+            FileRootSummary(
+                id=root.id,
+                label=root.label,
+                path=root.path,
+                resolved_path=str(resolved),
+            )
+        )
+    return FileRootsResponse(roots=roots)
+
+
+@router.get("/tree", response_model=FileTreeResponse)
+async def get_tree(
+    root_id: str = Query(...),
+    path: str = Query(""),
+) -> FileTreeResponse:
+    """List one directory level under the selected root."""
+    settings = _load_settings()
+    root_dir, target, rel = _resolve_target(settings, root_id, path, allow_root=True)
+    if not target.exists():
+        raise HTTPException(status_code=404, detail="Path not found")
+    if not target.is_dir():
+        raise HTTPException(status_code=400, detail="Path is not a directory")
+
+    tracker = _blocked_tracker(settings)
+    children = sorted(target.iterdir(), key=lambda child: (not child.is_dir(), child.name.casefold()))
+    entries = [
+        _entry_from_path(root_dir, child)
+        for child in children
+        if not tracker.is_excluded_from_generic(child)
+    ]
+    return FileTreeResponse(root_id=root_id, path=rel, entries=entries)
+
+
+@router.get("/content", response_model=FileContentResponse)
+async def get_content(
+    root_id: str = Query(...),
+    path: str = Query(...),
+) -> FileContentResponse:
+    """Return file metadata and inline content when safely editable."""
+    settings = _load_settings()
+    _root_dir, target, rel = _resolve_target(settings, root_id, path)
+    if not target.exists():
+        raise HTTPException(status_code=404, detail="Path not found")
+    if not target.is_file():
+        raise HTTPException(status_code=400, detail="Path is not a file")
+    return _content_response(
+        root_id,
+        rel,
+        target,
+        inline_cap=max_inline_edit_bytes_cap(settings),
+    )
+
+
+@router.get("/download")
+async def download_file(
+    root_id: str = Query(...),
+    path: str = Query(...),
+):
+    """Return the raw file for download or preview."""
+    settings = _load_settings()
+    _root_dir, target, _rel = _resolve_target(settings, root_id, path)
+    if not target.exists():
+        raise HTTPException(status_code=404, detail="Path not found")
+    if not target.is_file():
+        raise HTTPException(status_code=400, detail="Path is not a file")
+    return FileResponse(
+        target,
+        media_type=_mime_type(target),
+        filename=target.name,
+    )
+
+
+@router.put("/content", response_model=FileContentUpdateResponse)
+async def put_content(req: FileContentUpdateRequest) -> FileContentUpdateResponse:
+    """Overwrite a text file when revision still matches."""
+    settings = _load_settings()
+    inline_cap = max_inline_edit_bytes_cap(settings)
+    _root, root_dir = _resolve_root(settings, req.root_id)
+    _reject_if_symlink_alias(root_dir, req.path, action="overwrite")
+    _root_dir, target, rel = _resolve_target(settings, req.root_id, req.path)
+
+    rendered = req.content.encode("utf-8")
+    if len(rendered) > inline_cap:
+        raise HTTPException(
+            status_code=413,
+            detail=f"Content exceeds max inline edit size ({inline_cap} bytes)",
+        )
+
+    current_revision = "0"
+    if target.exists():
+        if not target.is_file():
+            raise HTTPException(status_code=400, detail="Path is not a file")
+        current = _content_response(req.root_id, rel, target, inline_cap=inline_cap)
+        current_revision = current.revision
+        if current.too_large:
+            raise HTTPException(
+                status_code=413,
+                detail=f"File exceeds max inline edit size ({inline_cap} bytes)",
+            )
+        if not current.inline_editable:
+            raise HTTPException(
+                status_code=415,
+                detail="File is not UTF-8 text; refusing inline overwrite",
+            )
+
+    if current_revision != req.revision:
+        raise HTTPException(status_code=409, detail="Stale revision")
+
+    target.parent.mkdir(parents=True, exist_ok=True)
+    target.write_text(req.content, encoding="utf-8")
+    return FileContentUpdateResponse(
+        path=rel,
+        revision=revision_token(target),
+        size=target.stat().st_size,
+    )
+
+
+@router.post("/upload", response_model=FileUploadResponse)
+async def upload_file(
+    root_id: str = Form(...),
+    path: str = Form(""),
+    file: UploadFile = File(...),
+) -> FileUploadResponse:
+    """Upload one file into a selected directory under an allowlisted root."""
+    settings = _load_settings()
+    _root, root_dir = _resolve_root(settings, root_id)
+    _reject_if_symlink_alias(root_dir, path, action="upload")
+    root_dir, target_dir, _rel = _resolve_target(settings, root_id, path, allow_root=True)
+    if target_dir.exists() and not target_dir.is_dir():
+        raise HTTPException(status_code=400, detail="Upload target is not a directory")
+    target_dir.mkdir(parents=True, exist_ok=True)
+
+    filename = Path(file.filename or "").name
+    if not filename:
+        raise HTTPException(status_code=400, detail="Upload filename is required")
+
+    destination = target_dir / filename
+    detail = _blocked_tracker(settings).exclusion_detail(destination)
+    if detail is not None:
+        raise HTTPException(
+            status_code=403,
+            detail=detail,
+        )
+    if destination.exists():
+        raise HTTPException(status_code=409, detail="Destination already exists")
+
+    written = 0
+    try:
+        with destination.open("wb") as handle:
+            while True:
+                chunk = await file.read(1024 * 1024)
+                if not chunk:
+                    break
+                written += len(chunk)
+                if written > UPLOAD_MAX_BYTES:
+                    handle.close()
+                    destination.unlink(missing_ok=True)
+                    raise HTTPException(
+                        status_code=413,
+                        detail="Uploaded file exceeds the 50 MB limit",
+                    )
+                handle.write(chunk)
+    finally:
+        await file.close()
+
+    return FileUploadResponse(entry=_entry_from_path(root_dir, destination))
+
+
+@router.post("/folder", response_model=FileFolderCreateResponse)
+async def create_folder(req: FileFolderCreateRequest) -> FileFolderCreateResponse:
+    """Create one folder path under an allowlisted root."""
+    settings = _load_settings()
+    _root, root_dir = _resolve_root(settings, req.root_id)
+    _reject_if_symlink_alias(root_dir, req.path, action="create folders")
+    _root_dir, target, rel = _resolve_target(settings, req.root_id, req.path)
+    if target.exists():
+        raise HTTPException(status_code=409, detail="Path already exists")
+    target.mkdir(parents=True, exist_ok=False)
+    return FileFolderCreateResponse(path=rel)
+
+
+@router.post("/rename", response_model=FileRenameResponse)
+async def rename_entry(req: FileRenameRequest) -> FileRenameResponse:
+    """Rename or move one entry within the same allowlisted root."""
+    settings = _load_settings()
+    _root, root_dir = _resolve_root(settings, req.root_id)
+    _reject_if_symlink_alias(root_dir, req.path, action="rename")
+    _reject_if_symlink_alias(root_dir, req.new_path, action="rename into")
+    _root_dir, source, _source_rel = _resolve_target(settings, req.root_id, req.path)
+    _root_dir, destination, dest_rel = _resolve_target(settings, req.root_id, req.new_path)
+
+    if not source.exists():
+        raise HTTPException(status_code=404, detail="Path not found")
+    _reject_if_blocked_directory_ancestor(settings, source)
+    if destination.exists():
+        raise HTTPException(status_code=409, detail="Destination already exists")
+    if source == destination:
+        raise HTTPException(status_code=400, detail="Source and destination are the same")
+
+    destination.parent.mkdir(parents=True, exist_ok=True)
+    source.rename(destination)
+    return FileRenameResponse(path=dest_rel)
+
+
+@router.delete("", response_model=FileDeleteResponse)
+async def delete_entry(
+    root_id: str = Query(...),
+    path: str = Query(...),
+) -> FileDeleteResponse:
+    """Delete a file or folder under an allowlisted root."""
+    settings = _load_settings()
+    _root, root_dir = _resolve_root(settings, root_id)
+    _reject_if_symlink_alias(root_dir, path, action="delete")
+    _root_dir, target, rel = _resolve_target(settings, root_id, path)
+    if not target.exists():
+        raise HTTPException(status_code=404, detail="Path not found")
+    _reject_if_blocked_directory_ancestor(settings, target)
+
+    if target.is_dir():
+        shutil.rmtree(target)
+    else:
+        target.unlink()
+
+    return FileDeleteResponse(deleted=True, path=rel)
