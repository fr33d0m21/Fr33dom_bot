new file mode 100644
index 0000000..3d4c13c
--- /dev/null
+++ b/frontend/src/components/admin/OpenRouterSetup.tsx
@@ -0,0 +1,154 @@
+import { useEffect, useMemo, useState } from 'react'
+import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query'
+import { api } from '../../api/client'
+
+const TARGET_MODEL = 'minimax/minimax-m2.7'
+
+function readModelConfig(raw: Record<string, unknown> | undefined): { provider: string; model: string } {
+  const model = raw?.model
+  if (typeof model === 'string') {
+    return { provider: '', model }
+  }
+  if (model && typeof model === 'object') {
+    const value = model as Record<string, unknown>
+    return {
+      provider: String(value.provider || ''),
+      model: String(value.default || value.model || ''),
+    }
+  }
+  return { provider: '', model: '' }
+}
+
+export function OpenRouterSetup({ gatewayRunning }: { gatewayRunning: boolean }) {
+  const queryClient = useQueryClient()
+  const { data: configData } = useQuery({
+    queryKey: ['config'],
+    queryFn: api.config,
+  })
+  const { data: envData } = useQuery({
+    queryKey: ['env-variables'],
+    queryFn: api.envVariables,
+  })
+
+  const [apiKey, setApiKey] = useState('')
+  const [notice, setNotice] = useState('')
+
+  const keyEntry = envData?.variables.find((entry) => entry.key === 'OPENROUTER_API_KEY')
+  const openRouterConfigured = Boolean(keyEntry && keyEntry.value && keyEntry.value !== '(empty)')
+  const current = useMemo(() => readModelConfig(configData?.config), [configData?.config])
+  const modelReady = current.provider === 'openrouter' && current.model === TARGET_MODEL
+
+  useEffect(() => {
+    setNotice('')
+  }, [apiKey])
+
+  const applySetup = useMutation({
+    mutationFn: async () => {
+      if (!openRouterConfigured && !apiKey.trim()) {
+        throw new Error('Enter an OpenRouter API key first.')
+      }
+      if (apiKey.trim()) {
+        await api.patchEnv('OPENROUTER_API_KEY', apiKey.trim())
+      }
+      await api.patchConfig('model.provider', 'openrouter')
+      await api.patchConfig('model.default', TARGET_MODEL)
+      return gatewayRunning ? api.adminGatewayRestart() : api.adminGatewayStart()
+    },
+    onSuccess: () => {
+      setNotice('Saved OpenRouter config, set MiniMax M2.7, and refreshed the gateway.')
+      setApiKey('')
+      queryClient.invalidateQueries({ queryKey: ['config'] })
+      queryClient.invalidateQueries({ queryKey: ['env-variables'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-status'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-config'] })
+    },
+    onError: (error) => {
+      setNotice(error instanceof Error ? error.message : 'Failed to save model settings')
+    },
+  })
+
+  return (
+    <div
+      className="rounded-xl border p-5 space-y-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
+        <div>
+          <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+            AI Provider Setup
+          </h3>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Save your OpenRouter key, switch the runtime to OpenRouter, and pin the default model to MiniMax M2.7.
+          </p>
+        </div>
+        <div className="flex gap-2 flex-wrap">
+          <Status label="API key" ready={openRouterConfigured} />
+          <Status label="Model" ready={modelReady} />
+        </div>
+      </div>
+
+      <div className="grid gap-4 md:grid-cols-[2fr,1fr,1fr]">
+        <label className="flex flex-col gap-1.5">
+          <span className="text-sm font-medium">OpenRouter API key</span>
+          <input
+            type="password"
+            value={apiKey}
+            onChange={(e) => setApiKey(e.target.value)}
+            placeholder={openRouterConfigured ? 'Configured - leave blank to keep current key' : 'sk-or-v1-...'}
+            className="w-full rounded-lg border px-3 py-2 text-sm"
+            style={{
+              borderColor: 'var(--color-border)',
+              backgroundColor: 'var(--color-bg)',
+              color: 'var(--color-text)',
+            }}
+          />
+          <span className="text-xs" style={{ color: 'var(--color-text-muted)' }}>
+            Stored in `~/.hermes/.env` as `OPENROUTER_API_KEY`.
+          </span>
+        </label>
+
+        <InfoTile label="Provider" value={current.provider || 'unset'} />
+        <InfoTile label="Default model" value={current.model || 'unset'} />
+      </div>
+
+      <div className="flex flex-wrap items-center gap-3">
+        <button
+          onClick={() => applySetup.mutate()}
+          disabled={applySetup.isPending}
+          className="rounded-lg px-4 py-2 text-sm font-medium"
+          style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+        >
+          {applySetup.isPending ? 'Applying...' : 'Use OpenRouter MiniMax M2.7'}
+        </button>
+        <span className="text-sm" style={{ color: notice ? 'var(--color-info)' : 'var(--color-text-muted)' }}>
+          {notice || 'This also starts or restarts the gateway.'}
+        </span>
+      </div>
+    </div>
+  )
+}
+
+function Status({ label, ready }: { label: string; ready: boolean }) {
+  return (
+    <span
+      className="rounded-full px-3 py-1 text-xs font-medium"
+      style={{
+        backgroundColor: ready ? 'rgba(43,253,28,0.12)' : 'rgba(255,107,143,0.12)',
+        color: ready ? 'var(--color-success)' : 'var(--color-error)',
+      }}
+    >
+      {label}: {ready ? 'ready' : 'needs setup'}
+    </span>
+  )
+}
+
+function InfoTile({ label, value }: { label: string; value: string }) {
+  return (
+    <div className="rounded-lg p-3" style={{ backgroundColor: 'var(--color-bg)' }}>
+      <div className="text-[11px] uppercase tracking-wide" style={{ color: 'var(--color-text-muted)' }}>
+        {label}
+      </div>
+      <div className="font-mono text-sm break-all">{value}</div>
+    </div>
+  )
+}
