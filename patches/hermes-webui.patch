+import type { ReactNode } from 'react'
+
+export interface TextEditorMetaItem {
+  label: string
+  value: string
+}
+
+export interface EditorNotice {
+  tone: 'success' | 'error' | 'info'
+  text: string
+}
+
+interface TextFileEditorProps {
+  title: string
+  description?: string
+  metaItems?: TextEditorMetaItem[]
+  notice?: EditorNotice | null
+  actions?: ReactNode
+  secondary?: ReactNode
+  children: ReactNode
+}
+
+const noticeStyles: Record<EditorNotice['tone'], { backgroundColor: string; color: string }> = {
+  success: {
+    backgroundColor: 'rgba(34,197,94,0.12)',
+    color: 'var(--color-success)',
+  },
+  error: {
+    backgroundColor: 'rgba(255,107,143,0.12)',
+    color: 'var(--color-error)',
+  },
+  info: {
+    backgroundColor: 'rgba(99,102,241,0.12)',
+    color: 'var(--color-info)',
+  },
+}
+
+export function TextFileEditor({
+  title,
+  description,
+  metaItems = [],
+  notice,
+  actions,
+  secondary,
+  children,
+}: TextFileEditorProps) {
+  return (
+    <section
+      className="rounded-xl border overflow-hidden"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex flex-col gap-4 border-b p-4 lg:flex-row lg:items-start lg:justify-between" style={{ borderColor: 'var(--color-border)' }}>
+        <div className="space-y-1">
+          <h3 className="text-lg font-semibold" style={{ color: 'var(--color-text)' }}>
+            {title}
+          </h3>
+          {description && (
+            <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+              {description}
+            </p>
+          )}
+        </div>
+        {actions && <div className="flex flex-wrap items-center gap-2">{actions}</div>}
+      </div>
+
+      {metaItems.length > 0 && (
+        <dl className="grid gap-3 border-b p-4 md:grid-cols-2 xl:grid-cols-3" style={{ borderColor: 'var(--color-border)' }}>
+          {metaItems.map((item) => (
+            <div key={item.label} className="space-y-1">
+              <dt className="text-[11px] uppercase tracking-[0.18em]" style={{ color: 'var(--color-text-muted)' }}>
+                {item.label}
+              </dt>
+              <dd
+                className="rounded-lg border px-3 py-2 text-sm font-mono break-all"
+                style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)', color: 'var(--color-text)' }}
+              >
+                {item.value}
+              </dd>
+            </div>
+          ))}
+        </dl>
+      )}
+
+      {notice && (
+        <div className="px-4 pt-4">
+          <div
+            role={notice.tone === 'error' ? 'alert' : 'status'}
+            className="rounded-lg px-3 py-2 text-sm"
+            style={noticeStyles[notice.tone]}
+          >
+            {notice.text}
+          </div>
+        </div>
+      )}
+
+      <div className={secondary ? 'grid gap-4 p-4 xl:grid-cols-[minmax(0,1fr)_320px]' : 'p-4'}>
+        <div className="min-w-0">{children}</div>
+        {secondary && <div className="min-w-0">{secondary}</div>}
+      </div>
+    </section>
+  )
+}
diff --git a/frontend/src/components/files/FileBrowser.tsx b/frontend/src/components/files/FileBrowser.tsx
