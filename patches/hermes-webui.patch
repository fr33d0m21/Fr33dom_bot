+def _proxy_request_headers(request: Request) -> dict[str, str]:
+    return {
+        key: value
+        for key, value in request.headers.items()
+        if key.lower() not in HOP_BY_HOP_HEADERS | {"host", "cookie", "x-hermes-token", "content-length"}
+    }
+
+
+def _proxy_response_headers(headers: httpx.Headers) -> dict[str, str]:
+    return {
+        key: value
+        for key, value in headers.items()
+        if key.lower() not in HOP_BY_HOP_HEADERS and key.lower() != "content-length"
+    }
+
+
+async def _proxy_http(request: Request, target_key: str) -> Response:
+    target = TTYD_TARGETS[target_key]
+    url = f"{target['http']}{request.url.path}"
+    if request.url.query:
+        url = f"{url}?{request.url.query}"
+
+    async with httpx.AsyncClient(follow_redirects=False, timeout=60.0) as client:
+        upstream = await client.request(
+            request.method,
+            url,
+            content=await request.body(),
+            headers=_proxy_request_headers(request),
+        )
+
+    return Response(
+        content=upstream.content,
+        status_code=upstream.status_code,
+        headers=_proxy_response_headers(upstream.headers),
+    )
+
+
+async def _proxy_websocket(websocket: WebSocket, target_key: str) -> None:
+    if not await validate_ws_token(websocket):
+        await websocket.close(code=4401, reason="Authentication required")
+        return
+
+    target = TTYD_TARGETS[target_key]
+    upstream_url = f"{target['ws']}{websocket.url.path}"
+    if websocket.url.query:
+        upstream_url = f"{upstream_url}?{websocket.url.query}"
+
+    requested_protocols = websocket.headers.get("sec-websocket-protocol", "")
+    client_subprotocols = [part.strip() for part in requested_protocols.split(",") if part.strip()]
+    if not client_subprotocols:
+        client_subprotocols = list(websocket.scope.get("subprotocols") or [])
+    connect_kwargs: dict[str, object] = {}
+    if client_subprotocols:
+        connect_kwargs["subprotocols"] = client_subprotocols
+
+    async with websockets.connect(upstream_url, **connect_kwargs) as upstream:
+        accept_subprotocol = upstream.subprotocol or (client_subprotocols[0] if client_subprotocols else None)
+        await websocket.accept(subprotocol=accept_subprotocol)
+
+        async def client_to_upstream() -> None:
+            while True:
+                message = await websocket.receive()
+                if message["type"] == "websocket.disconnect":
+                    break
+                if message.get("text") is not None:
+                    await upstream.send(message["text"])
+                elif message.get("bytes") is not None:
+                    await upstream.send(message["bytes"])
+
+        async def upstream_to_client() -> None:
+            while True:
+                message = await upstream.recv()
+                if isinstance(message, bytes):
+                    await websocket.send_bytes(message)
+                else:
+                    await websocket.send_text(message)
+
+        tasks = {
+            asyncio.create_task(client_to_upstream()),
+            asyncio.create_task(upstream_to_client()),
+        }
+        done, pending = await asyncio.wait(tasks, return_when=asyncio.FIRST_COMPLETED)
+        for task in pending:
+            task.cancel()
+        await asyncio.gather(*pending, return_exceptions=True)
+        for task in done:
+            task.result()
 
 
