+                    className="rounded-lg px-4 py-2 text-sm font-medium disabled:opacity-50"
+                    style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+                  >
+                    {updateMutation.isPending ? 'Saving...' : 'Save'}
+                  </button>
+                </>
+              }
+              secondary={
+                <FileMetadataPanel
+                  exactPath={selectedExactPath}
+                  items={metadataItems}
+                />
+              }
+            >
+              {contentQuery.isLoading ? (
+                <StatePanel
+                  title="Loading file"
+                  description="Fetching the latest file metadata and inline content."
+                />
+              ) : contentError && isManagedPathError(contentError) ? (
+                <StatePanel
+                  title="Managed in Personality"
+                  description="This path is managed in Personality, so Files will not read or overwrite it here."
+                  action={
+                    <Link
+                      to="/personality"
+                      className="inline-flex rounded-lg px-3 py-2 text-sm font-medium no-underline"
+                      style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+                    >
+                      Open Personality
+                    </Link>
+                  }
+                />
+              ) : contentError ? (
+                <StatePanel
+                  title="Could not load file"
+                  description={loadFailureMessage(contentQuery.error, 'Failed to load the selected file.')}
+                  action={
+                    <button
+                      type="button"
+                      onClick={() => {
+                        void handleRefresh()
+                      }}
+                      className="rounded-lg px-3 py-2 text-sm font-medium"
+                      style={{ backgroundColor: 'var(--color-primary)', color: '#041205' }}
+                    >
+                      Retry
+                    </button>
+                  }
+                />
+              ) : activeContent?.is_image ? (
+                <div className="space-y-4">
+                  <div
+                    className="rounded-lg border border-dashed p-4 text-sm"
+                    style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)', color: 'var(--color-text-muted)' }}
+                  >
+                    Inline editing is disabled for this image, but you can preview it here or download the original bytes.
+                  </div>
+                  {downloadHref && (
+                    <img
+                      src={downloadHref}
+                      alt={activeContent.name}
+                      className="max-h-[520px] w-full rounded-lg border object-contain"
+                      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)' }}
+                    />
+                  )}
+                </div>
+              ) : activeContent?.too_large ? (
+                <StatePanel
+                  title="File too large for inline editing"
+                  description="This text file exceeds the inline edit limit. Download it or open it in another editor."
+                />
+              ) : activeContent && !activeContent.inline_editable ? (
+                <StatePanel
+                  title="Unsupported binary edit"
+                  description="This file is not UTF-8 text, so Files will not overwrite it inline. Use the metadata and download action instead."
+                />
+              ) : activeContent ? (
+                <textarea
+                  aria-label="File content"
+                  value={draftContent}
+                  onChange={(event) => handleDraftChange(event.target.value)}
+                  className="min-h-[520px] w-full rounded-lg border p-3 text-sm font-mono outline-none"
+                  style={{
+                    borderColor: 'var(--color-border)',
+                    backgroundColor: 'var(--color-bg)',
+                    color: 'var(--color-text)',
+                  }}
+                />
+              ) : (
+                <StatePanel
+                  title="No file loaded"
+                  description="Choose another file from the browser rail to load its current metadata and content."
+                />
+              )}
+            </TextFileEditor>
+          ) : (
+            <section
+              className="rounded-xl border p-6"
+              style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+            >
+              <StatePanel
+                title="Select a file"
+                description="Choose a file from the browser rail to edit text inline, preview images, or inspect metadata before downloading."
+              />
+            </section>
+          )}
+        </div>
+      )}
+    </div>
+  )
+}
