+import type { ReactNode } from 'react'
+
+export interface FileMetadataItem {
+  label: string
+  value: string
+}
+
+interface FileMetadataPanelProps {
+  title?: string
+  description?: string
+  exactPath: string
+  items?: FileMetadataItem[]
+  actions?: ReactNode
+}
+
+export function FileMetadataPanel({
+  title = 'File metadata',
+  description = 'Use the exact resolved path below to confirm you are editing or downloading the intended file.',
+  exactPath,
+  items = [],
+  actions,
+}: FileMetadataPanelProps) {
+  return (
+    <aside
+      className="rounded-xl border p-4 space-y-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-bg)' }}
+    >
+      <div className="space-y-1">
+        <h4 className="text-sm font-semibold" style={{ color: 'var(--color-text)' }}>
+          {title}
+        </h4>
+        <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+          {description}
+        </p>
+      </div>
+
+      <div className="space-y-1">
+        <div
+          className="text-[11px] uppercase tracking-[0.18em]"
+          style={{ color: 'var(--color-text-muted)' }}
+        >
+          Exact path
+        </div>
+        <div
+          className="rounded-lg border px-3 py-2 text-sm font-mono break-all"
+          style={{
+            borderColor: 'var(--color-border)',
+            backgroundColor: 'var(--color-surface)',
+            color: 'var(--color-text)',
+          }}
+        >
+          {exactPath}
+        </div>
+      </div>
+
+      {items.length > 0 && (
+        <dl className="space-y-3">
+          {items.map((item) => (
+            <div key={item.label} className="space-y-1">
+              <dt
+                className="text-[11px] uppercase tracking-[0.18em]"
+                style={{ color: 'var(--color-text-muted)' }}
+              >
+                {item.label}
+              </dt>
+              <dd
+                className="rounded-lg border px-3 py-2 text-sm break-all"
+                style={{
+                  borderColor: 'var(--color-border)',
+                  backgroundColor: 'var(--color-surface)',
+                  color: 'var(--color-text)',
+                }}
+              >
+                {item.value}
+              </dd>
+            </div>
+          ))}
+        </dl>
+      )}
+
+      {actions && <div className="flex flex-wrap gap-2">{actions}</div>}
+    </aside>
+  )
+}
