@@ -0,0 +1,292 @@
+"""Tests for runtime filesystem path safety helpers."""
+
+import pytest
+
+from webui.dashboard_settings import (
+    DashboardSettings,
+    FileRoot,
+    PersonalityFileRef,
+    load_dashboard_settings,
+)
+from webui.runtime_fs import (
+    AbsolutePathInRelativeError,
+    Fr33domBotExposureError,
+    ManagedPathTracker,
+    PathOutsideRootError,
+    PathTraversalError,
+    expand_dashboard_path,
+    find_file_root,
+    max_inline_edit_bytes_cap,
+    normalize_relative,
+    resolve_personality_file,
+    resolve_under_root,
+    resolve_with_symlinks_checked,
+    revision_token,
+    text_binary_probe,
+    validate_root_path,
+    resolve_root_directory,
+)
+
+
+def test_find_file_root():
+    roots = [
+        FileRoot(id="a", path="/tmp", label="A"),
+        FileRoot(id="b", path="/var", label="B"),
+    ]
+    assert find_file_root(roots, "b") == roots[1]
+    assert find_file_root(roots, "missing") is None
+
+
+def test_normalize_relative_accepts_child_path():
+    assert normalize_relative("notes/readme.md") == "notes/readme.md"
+
+
+def test_normalize_relative_rejects_dot_dot():
+    with pytest.raises(PathTraversalError):
+        normalize_relative("../etc/passwd")
+    with pytest.raises(PathTraversalError):
+        normalize_relative("a/../b")
+
+
+def test_normalize_relative_rejects_absolute():
+    with pytest.raises(AbsolutePathInRelativeError):
+        normalize_relative("/tmp/x")
+
+
+def test_resolve_child_under_root(fake_user_home, temp_hermes_home):
+    root = expand_dashboard_path(
+        "~/.hermes",
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    ).resolve()
+    target = resolve_under_root(root, "SOUL.md", home=fake_user_home)
+    assert target == temp_hermes_home / "SOUL.md"
+
+
+def test_rejects_fr33dom_bot_relative_path(fake_user_home):
+    fb = fake_user_home / "Fr33dom_bot"
+    fb.mkdir()
+    (fb / "x.txt").write_text("secret", encoding="utf-8")
+    with pytest.raises(Fr33domBotExposureError):
+        resolve_under_root(fake_user_home.resolve(), "Fr33dom_bot/x.txt", home=fake_user_home)
+
+
+def test_validate_root_rejects_fr33dom_bot_directory(fake_user_home):
+    fb = fake_user_home / "Fr33dom_bot"
+    fb.mkdir()
+    with pytest.raises(Fr33domBotExposureError):
+        validate_root_path(fb, home=fake_user_home)
+
+
+def test_validate_root_rejects_fr33dom_bot_even_when_directory_not_created_yet(fake_user_home):
+    """Canonical ~/Fr33dom_bot must be blocked before the folder exists."""
+    fb = fake_user_home / "Fr33dom_bot"
+    assert not fb.exists()
+    with pytest.raises(Fr33domBotExposureError):
+        validate_root_path(fb, home=fake_user_home)
+
+
+def test_validate_root_rejects_home_directory_as_root(fake_user_home):
+    """A root at ~ would later expose ~/Fr33dom_bot as a subdirectory."""
+    with pytest.raises(Fr33domBotExposureError):
+        validate_root_path(fake_user_home.resolve(), home=fake_user_home)
+
+
+def test_validate_root_allows_non_ancestor_path(fake_user_home, tmp_path):
+    """Sibling trees under tmp are not Fr33dom_bot ancestors."""
+    other = tmp_path / "safe_root"
+    other.mkdir()
+    got = validate_root_path(other, home=fake_user_home)
+    assert got == other.resolve()
+
+
+def test_rejects_fr33dom_bot_relative_path_when_bot_dir_not_created(fake_user_home):
+    fb = fake_user_home / "Fr33dom_bot"
+    assert not fb.exists()
+    with pytest.raises(Fr33domBotExposureError):
+        resolve_under_root(fake_user_home.resolve(), "Fr33dom_bot/x.txt", home=fake_user_home)
+
+
+def test_symlink_escape_outside_root_raises(fake_user_home, temp_hermes_home):
+    jail = temp_hermes_home / "jail"
+    jail.mkdir()
+    outside = temp_hermes_home / "outside_secret.txt"
+    outside.write_text("nope", encoding="utf-8")
+    link = jail / "bad"
+    link.symlink_to(outside)
+    with pytest.raises(PathOutsideRootError):
+        resolve_with_symlinks_checked(jail, "bad", home=fake_user_home)
+
+
+def test_symlink_inside_root_still_allowed(fake_user_home, temp_hermes_home):
+    jail = temp_hermes_home / "jail"
+    jail.mkdir()
+    inner = jail / "inner.txt"
+    inner.write_text("ok", encoding="utf-8")
+    link = jail / "good"
+    link.symlink_to(inner)
+    got = resolve_with_symlinks_checked(
+        temp_hermes_home, "jail/good", home=fake_user_home
+    )
+    assert got.resolve() == inner.resolve()
+
+
+def test_managed_path_tracker_marks_personality_paths(
+    fake_user_home, temp_hermes_home,
+):
+    s = load_dashboard_settings(hermes_home=temp_hermes_home)
+    tracker = ManagedPathTracker.from_settings(
+        s,
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    )
+    soul = (temp_hermes_home / "SOUL.md").resolve()
+    assert tracker.is_excluded_from_generic(soul)
+    assert not tracker.is_excluded_from_generic(temp_hermes_home / "config.yaml")
+
+
+def test_managed_path_tracker_marks_ancestors_of_managed_paths(
+    fake_user_home, temp_hermes_home,
+):
+    nested = temp_hermes_home / "personality"
+    nested.mkdir()
+    managed = nested / "soul.md"
+    managed.write_text("x", encoding="utf-8")
+    settings = DashboardSettings(
+        file_roots=[FileRoot(id="hermes-home", path="~/.hermes", label="Hermes Home")],
+        personality_files=[
+            PersonalityFileRef(
+                id="soul",
+                label="SOUL",
+                root_id="hermes-home",
+                path="personality/soul.md",
+            )
+        ],
+    )
+    tracker = ManagedPathTracker.from_settings(
+        settings,
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    )
+    assert tracker.is_ancestor_of_managed_path(temp_hermes_home)
+    assert tracker.is_ancestor_of_managed_path(nested)
+    assert not tracker.is_ancestor_of_managed_path(managed)
+    assert not tracker.is_ancestor_of_managed_path(temp_hermes_home / "config.yaml")
+
+
+def test_managed_path_tracker_keeps_optional_extra_managed_paths(
+    fake_user_home, temp_hermes_home,
+):
+    extra = temp_hermes_home / "notes.md"
+    extra.write_text("managed outside Personality\n", encoding="utf-8")
+    settings = DashboardSettings(
+        file_roots=[FileRoot(id="hermes-home", path="~/.hermes", label="Hermes Home")],
+        personality_files=[
+            PersonalityFileRef(
+                id="soul",
+                label="SOUL",
+                root_id="hermes-home",
+                path="SOUL.md",
+            )
+        ],
+        managed_paths=[str(extra.resolve())],
+    )
+
+    tracker = ManagedPathTracker.from_settings(
+        settings,
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    )
+
+    assert tracker.is_excluded_from_generic(temp_hermes_home / "SOUL.md")
+    assert tracker.is_excluded_from_generic(extra)
+
+
+def test_managed_path_tracker_keeps_hidden_paths(
+    fake_user_home, temp_hermes_home,
+):
+    hidden_dir = temp_hermes_home / "extensions" / "hermes-webui"
+    hidden_dir.mkdir(parents=True)
+    hidden_file = hidden_dir / "README.md"
+    hidden_file.write_text("maintenance\n", encoding="utf-8")
+    settings = DashboardSettings(
+        hidden_paths=["~/.hermes/extensions/hermes-webui"],
+    )
+
+    tracker = ManagedPathTracker.from_settings(
+        settings,
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    )
+
+    assert tracker.is_excluded_from_generic(hidden_dir)
+    assert tracker.is_excluded_from_generic(hidden_file)
+    assert not tracker.is_excluded_from_generic(temp_hermes_home / "extensions")
+
+
+def test_managed_path_tracker_marks_ancestors_of_hidden_paths(
+    fake_user_home, temp_hermes_home,
+):
+    hidden_dir = temp_hermes_home / "patches"
+    hidden_dir.mkdir()
+    hidden_file = hidden_dir / "hermes-webui.patch"
+    hidden_file.write_text("diff --git\n", encoding="utf-8")
+    settings = DashboardSettings(hidden_paths=["~/.hermes/patches"])
+
+    tracker = ManagedPathTracker.from_settings(
+        settings,
+        home=fake_user_home,
+        hermes_home=temp_hermes_home,
+    )
+
+    assert tracker.is_ancestor_of_excluded_path(temp_hermes_home)
+    assert tracker.is_excluded_from_generic(hidden_dir)
+    assert not tracker.is_ancestor_of_excluded_path(hidden_dir)
+    assert not tracker.is_ancestor_of_excluded_path(hidden_file)
+    assert not tracker.is_ancestor_of_excluded_path(temp_hermes_home / "config.yaml")
+
+
+def test_revision_token_uses_mtime_ns(temp_hermes_home):
+    p = temp_hermes_home / "config.yaml"
+    tok = revision_token(p)
+    assert tok.isdigit()
+    assert int(tok) > 0
+
+
+def test_text_binary_probe(tmp_path):
+    t = tmp_path / "a.txt"
+    t.write_text("hello", encoding="utf-8")
+    assert text_binary_probe(t) == "text"
+    b = tmp_path / "b.bin"
+    b.write_bytes(b"\x00\xff")
+    assert text_binary_probe(b) == "binary"
+    invalid_utf8 = tmp_path / "invalid-utf8.txt"
+    invalid_utf8.write_bytes(b"\x80still-not-utf8")
+    assert text_binary_probe(invalid_utf8) == "binary"
+
+
+def test_max_inline_cap_from_settings():
+    s = DashboardSettings(max_inline_edit_bytes=99)
+    assert max_inline_edit_bytes_cap(s) == 99
+    assert max_inline_edit_bytes_cap(DashboardSettings()) == 1_000_000
+
+
+def test_resolve_root_directory_expands_tilde_paths(fake_user_home, temp_hermes_home):
+    s = load_dashboard_settings(hermes_home=temp_hermes_home)
+    hr = next(r for r in s.file_roots if r.id == "hermes-home")
+    path = resolve_root_directory(hr, home=fake_user_home, hermes_home=temp_hermes_home)
+    assert path == temp_hermes_home.resolve()
+
+
+def test_resolve_personality_file(fake_user_home, temp_hermes_home):
+    s = load_dashboard_settings(hermes_home=temp_hermes_home)
+    got = resolve_personality_file(
+        s, "soul", home=fake_user_home, hermes_home=temp_hermes_home
+    )
+    assert got is not None
+    ref, path = got
+    assert ref.id == "soul"
+    assert path == (temp_hermes_home / "SOUL.md").resolve()
+    assert resolve_personality_file(
+        s, "missing-id", home=fake_user_home, hermes_home=temp_hermes_home
+    ) is None
