@@ -0,0 +1,475 @@
+import { useEffect, useMemo, useState, type ReactNode } from 'react'
+import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query'
+import { api } from '../api/client'
+import type { GatewayField, GatewayPlatformConfig } from '../api/types'
+
+type Drafts = Record<string, Record<string, string>>
+type Notice = { tone: 'success' | 'error' | 'info'; text: string }
+
+function toneColor(tone: Notice['tone']): string {
+  if (tone === 'success') return 'var(--color-success)'
+  if (tone === 'error') return 'var(--color-error)'
+  return 'var(--color-info)'
+}
+
+export function Gateway() {
+  const queryClient = useQueryClient()
+  const { data, isLoading, error } = useQuery({
+    queryKey: ['gateway-config'],
+    queryFn: api.gatewayConfig,
+  })
+  const { data: gatewayStatus } = useQuery({
+    queryKey: ['gateway-status'],
+    queryFn: api.gatewayStatus,
+    refetchInterval: 5000,
+  })
+
+  const [drafts, setDrafts] = useState<Drafts>({})
+  const [globalDraft, setGlobalDraft] = useState({
+    gateway_allow_all_users: 'false',
+    unauthorized_dm_behavior: 'pair',
+  })
+  const [notices, setNotices] = useState<Record<string, Notice>>({})
+
+  useEffect(() => {
+    if (!data) return
+    setDrafts((current) => {
+      if (Object.keys(current).length > 0) return current
+      return Object.fromEntries(
+        data.platforms.map((platform) => [
+          platform.key,
+          Object.fromEntries(platform.fields.map((field) => [field.key, field.value || ''])),
+        ]),
+      )
+    })
+    setGlobalDraft({
+      gateway_allow_all_users: data.gateway_allow_all_users ? 'true' : 'false',
+      unauthorized_dm_behavior: data.unauthorized_dm_behavior || 'pair',
+    })
+  }, [data])
+
+  const savePlatform = useMutation({
+    mutationFn: ({ platform, fields }: { platform: string; fields: Record<string, string> }) =>
+      api.patchGatewayConfig(platform, { fields }),
+    onSuccess: (result) => {
+      setNotices((current) => ({
+        ...current,
+        [result.platform]: {
+          tone: 'success',
+          text: result.updated_fields.length
+            ? 'Saved. Restart the gateway if it is already running.'
+            : 'No changes were needed.',
+        },
+      }))
+      queryClient.invalidateQueries({ queryKey: ['gateway-config'] })
+      queryClient.invalidateQueries({ queryKey: ['gateway-status'] })
+    },
+    onError: (err, variables) => {
+      setNotices((current) => ({
+        ...current,
+        [variables.platform]: { tone: 'error', text: err instanceof Error ? err.message : 'Failed to save platform' },
+      }))
+    },
+  })
+
+  const saveGlobal = useMutation({
+    mutationFn: () =>
+      api.patchGatewayConfig('global', {
+        fields: { GATEWAY_ALLOW_ALL_USERS: globalDraft.gateway_allow_all_users },
+        config: { unauthorized_dm_behavior: globalDraft.unauthorized_dm_behavior },
+      }),
+    onSuccess: () => {
+      setNotices((current) => ({
+        ...current,
+        global: {
+          tone: 'success',
+          text: 'Global gateway defaults saved. Restart the gateway to apply policy changes.',
+        },
+      }))
+      queryClient.invalidateQueries({ queryKey: ['gateway-config'] })
+    },
+    onError: (err) => {
+      setNotices((current) => ({
+        ...current,
+        global: { tone: 'error', text: err instanceof Error ? err.message : 'Failed to save global settings' },
+      }))
+    },
+  })
+
+  const testPlatform = useMutation({
+    mutationFn: (platform: string) => api.testGatewayPlatform(platform),
+    onSuccess: (result) => {
+      setNotices((current) => ({
+        ...current,
+        [result.platform]: {
+          tone: result.success ? 'success' : 'info',
+          text: result.missing_fields.length
+            ? `${result.message}: ${result.missing_fields.join(', ')}`
+            : result.message,
+        },
+      }))
+    },
+    onError: (err, platform) => {
+      setNotices((current) => ({
+        ...current,
+        [platform]: { tone: 'error', text: err instanceof Error ? err.message : 'Test failed' },
+      }))
+    },
+  })
+
+  const configuredCount = useMemo(
+    () => data?.platforms.filter((platform) => platform.configured).length ?? 0,
+    [data],
+  )
+
+  if (isLoading) return <div className="p-6">Loading gateway configuration...</div>
+  if (error || !data) return <div className="p-6" style={{ color: 'var(--color-error)' }}>Failed to load gateway configuration</div>
+
+  return (
+    <div className="p-6 space-y-6">
+      <div className="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
+        <div>
+          <h2 className="text-2xl font-semibold">Messaging Gateways</h2>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Configure trusted messaging channels, save credentials, and use pairing without leaving the dashboard.
+          </p>
+        </div>
+        <div className="flex flex-wrap gap-2">
+          <InlineStat label="Configured" value={`${configuredCount}/${data.platforms.length}`} />
+          <InlineStat label="Gateway" value={gatewayStatus?.running ? 'Running' : 'Stopped'} tone={gatewayStatus?.running ? 'success' : 'error'} />
+        </div>
+      </div>
+
+      <div
+        className="rounded-xl border p-5 space-y-4"
+        style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+      >
+        <div className="flex flex-col gap-1">
+          <h3 className="text-sm font-semibold uppercase tracking-wide" style={{ color: 'var(--color-primary)' }}>
+            Security Defaults
+          </h3>
+          <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+            Hermes denies everyone by default. Use allowlists for trusted users, or keep pairing enabled so new users must request approval first.
+          </p>
+        </div>
+
+        <div className="grid gap-4 md:grid-cols-2">
+          <LabeledField label="Allow all users">
+            <select
+              value={globalDraft.gateway_allow_all_users}
+              onChange={(e) => setGlobalDraft((current) => ({ ...current, gateway_allow_all_users: e.target.value }))}
+              className="w-full rounded-lg border px-3 py-2 text-sm"
+              style={{
+                borderColor: 'var(--color-border)',
+                backgroundColor: 'var(--color-bg)',
+                color: 'var(--color-text)',
+              }}
+            >
+              <option value="false">false</option>
+              <option value="true">true</option>
+            </select>
+          </LabeledField>
+
+          <LabeledField label="Unauthorized DM behavior">
+            <select
+              value={globalDraft.unauthorized_dm_behavior}
+              onChange={(e) => setGlobalDraft((current) => ({ ...current, unauthorized_dm_behavior: e.target.value }))}
+              className="w-full rounded-lg border px-3 py-2 text-sm"
+              style={{
+                borderColor: 'var(--color-border)',
+                backgroundColor: 'var(--color-bg)',
+                color: 'var(--color-text)',
+              }}
+            >
+              <option value="pair">pair</option>
+              <option value="ignore">ignore</option>
+            </select>
+          </LabeledField>
+        </div>
+
+        <div className="flex flex-wrap items-center gap-3">
+          <button
+            onClick={() => saveGlobal.mutate()}
+            className="rounded-lg px-4 py-2 text-sm font-medium text-white"
+            style={{ backgroundColor: 'var(--color-primary)' }}
+            disabled={saveGlobal.isPending}
+          >
+            {saveGlobal.isPending ? 'Saving...' : 'Save security defaults'}
+          </button>
+          {notices.global && <NoticeText notice={notices.global} />}
+        </div>
+      </div>
+
+      <div className="grid gap-4 xl:grid-cols-2">
+        {data.platforms.map((platform) => (
+          <GatewayCard
+            key={platform.key}
+            platform={platform}
+            draft={drafts[platform.key] || {}}
+            notice={notices[platform.key]}
+            saving={savePlatform.isPending && savePlatform.variables?.platform === platform.key}
+            testing={testPlatform.isPending && testPlatform.variables === platform.key}
+            onChange={(fieldKey, value) =>
+              setDrafts((current) => ({
+                ...current,
+                [platform.key]: {
+                  ...(current[platform.key] || {}),
+                  [fieldKey]: value,
+                },
+              }))
+            }
+            onSave={() => savePlatform.mutate({ platform: platform.key, fields: drafts[platform.key] || {} })}
+            onTest={() => testPlatform.mutate(platform.key)}
+          />
+        ))}
+      </div>
+
+      <div
+        className="rounded-xl border p-5"
+        style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+      >
+        <h3 className="text-sm font-semibold uppercase tracking-wide mb-3" style={{ color: 'var(--color-primary)' }}>
+          Pairing Commands
+        </h3>
+        <div className="grid gap-2 md:grid-cols-2">
+          <CommandHint command="fr33d0m pairing list" description="See pending and approved pairing requests." />
+          <CommandHint command="fr33d0m pairing approve telegram CODE" description="Approve a pairing code from Telegram, Signal, Email, or Discord." />
+          <CommandHint command="fr33d0m gateway restart" description="Restart the gateway after saving credentials." />
+          <CommandHint command="fr33d0m whatsapp" description="Launch the WhatsApp pairing flow and scan the QR code." />
+        </div>
+      </div>
+    </div>
+  )
+}
+
+function GatewayCard({
+  platform,
+  draft,
+  notice,
+  saving,
+  testing,
+  onChange,
+  onSave,
+  onTest,
+}: {
+  platform: GatewayPlatformConfig
+  draft: Record<string, string>
+  notice?: Notice
+  saving: boolean
+  testing: boolean
+  onChange: (fieldKey: string, value: string) => void
+  onSave: () => void
+  onTest: () => void
+}) {
+  return (
+    <div
+      className="rounded-xl border p-5 flex flex-col gap-4"
+      style={{ borderColor: 'var(--color-border)', backgroundColor: 'var(--color-surface)' }}
+    >
+      <div className="flex items-start justify-between gap-4">
+        <div>
+          <div className="flex items-center gap-3">
+            <span className="text-2xl">{platform.emoji}</span>
+            <div>
+              <h3 className="text-lg font-semibold">{platform.label}</h3>
+              <p className="text-sm" style={{ color: 'var(--color-text-muted)' }}>
+                {platform.description}
+              </p>
+            </div>
+          </div>
+        </div>
+        <div className="flex flex-col items-end gap-2">
+          <StatusBadge configured={platform.configured} status={platform.status} />
+          {platform.docs_url && (
+            <a
+              href={platform.docs_url}
+              target="_blank"
+              rel="noreferrer"
+              className="text-xs no-underline"
+              style={{ color: 'var(--color-info)' }}
+            >
+              Setup guide
+            </a>
+          )}
+        </div>
+      </div>
+
+      <div className="grid gap-4 md:grid-cols-2">
+        {platform.fields.map((field) => (
+          <PlatformField
+            key={field.key}
+            field={field}
+            value={draft[field.key] ?? ''}
+            onChange={(value) => onChange(field.key, value)}
+          />
+        ))}
+      </div>
+
+      {platform.pairing_hint && (
+        <div
+          className="rounded-lg px-3 py-2 text-sm"
+          style={{ backgroundColor: 'var(--color-bg)', color: 'var(--color-text-muted)' }}
+        >
+          {platform.pairing_hint}
+        </div>
+      )}
+
+      <div className="flex flex-wrap items-center gap-3">
+        <button
+          onClick={onSave}
+          className="rounded-lg px-4 py-2 text-sm font-medium text-white"
+          style={{ backgroundColor: 'var(--color-primary)' }}
+          disabled={saving}
+        >
+          {saving ? 'Saving...' : 'Save platform'}
+        </button>
+        <button
+          onClick={onTest}
+          className="rounded-lg px-4 py-2 text-sm font-medium"
+          style={{
+            backgroundColor: 'var(--color-bg)',
+            color: 'var(--color-text)',
+            border: '1px solid var(--color-border)',
+          }}
+          disabled={testing}
+        >
+          {testing ? 'Checking...' : 'Test setup'}
+        </button>
+        {notice && <NoticeText notice={notice} />}
+      </div>
+    </div>
+  )
+}
+
+function PlatformField({
+  field,
+  value,
+  onChange,
+}: {
+  field: GatewayField
+  value: string
+  onChange: (value: string) => void
+}) {
+  const inputStyles = {
+    borderColor: 'var(--color-border)',
+    backgroundColor: 'var(--color-bg)',
+    color: 'var(--color-text)',
+  } as const
+
+  return (
+    <LabeledField
+      label={field.required ? `${field.label} *` : field.label}
+      hint={field.help}
+      badge={field.sensitive && field.configured ? 'configured' : undefined}
+    >
+      {field.input_type === 'select' ? (
+        <select
+          value={value || field.options[0] || ''}
+          onChange={(e) => onChange(e.target.value)}
+          className="w-full rounded-lg border px-3 py-2 text-sm"
+          style={inputStyles}
+        >
+          {field.options.map((option) => (
+            <option key={option} value={option}>
+              {option}
+            </option>
+          ))}
+        </select>
+      ) : (
+        <input
+          type={field.input_type}
+          value={value}
+          onChange={(e) => onChange(e.target.value)}
+          placeholder={field.placeholder || field.help}
+          className="w-full rounded-lg border px-3 py-2 text-sm"
+          style={inputStyles}
+        />
+      )}
+    </LabeledField>
+  )
+}
+
+function LabeledField({
+  label,
+  hint,
+  badge,
+  children,
+}: {
+  label: string
+  hint?: string
+  badge?: string
+  children: ReactNode
+}) {
+  return (
+    <label className="flex flex-col gap-1.5">
+      <span className="text-sm font-medium flex items-center gap-2">
+        {label}
+        {badge && (
+          <span
+            className="rounded-full px-2 py-0.5 text-[10px] uppercase tracking-wide"
+            style={{ backgroundColor: 'rgba(43,253,28,0.12)', color: 'var(--color-success)' }}
+          >
+            {badge}
+          </span>
+        )}
+      </span>
+      {children}
+      {hint && (
+        <span className="text-xs" style={{ color: 'var(--color-text-muted)' }}>
+          {hint}
+        </span>
+      )}
+    </label>
+  )
+}
+
+function StatusBadge({ configured, status }: { configured: boolean; status: string }) {
+  return (
+    <span
+      className="rounded-full px-2.5 py-1 text-xs font-medium"
+      style={{
+        backgroundColor: configured ? 'rgba(43,253,28,0.12)' : 'rgba(142,163,255,0.12)',
+        color: configured ? 'var(--color-success)' : 'var(--color-info)',
+      }}
+    >
+      {status}
+    </span>
+  )
+}
+
+function InlineStat({ label, value, tone }: { label: string; value: string; tone?: 'success' | 'error' }) {
+  return (
+    <div
+      className="rounded-lg px-3 py-2 text-sm"
+      style={{ backgroundColor: 'var(--color-surface)', border: '1px solid var(--color-border)' }}
+    >
+      <div className="text-[11px] uppercase tracking-wide" style={{ color: 'var(--color-text-muted)' }}>
+        {label}
+      </div>
+      <div style={{ color: tone === 'success' ? 'var(--color-success)' : tone === 'error' ? 'var(--color-error)' : 'var(--color-text)' }}>
+        {value}
+      </div>
+    </div>
+  )
+}
+
+function CommandHint({ command, description }: { command: string; description: string }) {
+  return (
+    <div className="rounded-lg p-3" style={{ backgroundColor: 'var(--color-bg)' }}>
+      <div className="font-mono text-xs mb-1" style={{ color: 'var(--color-primary)' }}>
+        {command}
+      </div>
+      <div className="text-xs" style={{ color: 'var(--color-text-muted)' }}>
+        {description}
+      </div>
+    </div>
+  )
+}
+
+function NoticeText({ notice }: { notice: Notice }) {
+  return (
+    <span className="text-sm" style={{ color: toneColor(notice.tone) }}>
+      {notice.text}
+    </span>
+  )
+}
