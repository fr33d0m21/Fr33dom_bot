+"""Tests for ~/.hermes/fr33d0m-dashboard.yaml loading."""
+
+from unittest.mock import patch
+
+from webui.dashboard_settings import (
+    DashboardSettings,
+    DASHBOARD_SETTINGS_FILE,
+    load_dashboard_settings,
+)
+
+
+def test_load_missing_file_returns_empty_defaults(tmp_path):
+    """If the YAML is absent, return empty lists and built-in defaults."""
+    empty_home = tmp_path / "hermes"
+    empty_home.mkdir()
+    with patch("webui.dashboard_settings.HERMES_HOME", empty_home):
+        s = load_dashboard_settings()
+    assert isinstance(s, DashboardSettings)
+    assert s.file_roots == []
+    assert s.personality_files == []
+    assert s.managed_paths == []
+    assert s.hidden_paths == []
+    assert s.max_inline_edit_bytes == 1_000_000
+
+
+def test_load_reads_fr33d0m_dashboard_yaml(temp_hermes_home):
+    """Loader reads fr33d0m-dashboard.yaml from HERMES_HOME."""
+    with patch("webui.dashboard_settings.HERMES_HOME", temp_hermes_home):
+        s = load_dashboard_settings()
+    assert (temp_hermes_home / DASHBOARD_SETTINGS_FILE).is_file()
+    assert len(s.file_roots) == 2
+    ids = {r.id for r in s.file_roots}
+    assert ids == {"hermes-home", "downloads"}
+    assert s.personality_files[0].id == "soul"
+    assert s.personality_files[0].root_id == "hermes-home"
+    assert s.managed_paths == []
+    assert s.hidden_paths == [
+        "~/.hermes/extensions/hermes-webui",
+        "~/.hermes/patches",
+    ]
+    assert s.max_inline_edit_bytes == 1_000_000
+
+
+def test_load_explicit_hermes_home_overrides_module_path(temp_hermes_home):
+    """Pass-through hermes_home works without relying on module global."""
+    s = load_dashboard_settings(hermes_home=temp_hermes_home)
+    assert len(s.file_roots) >= 1
