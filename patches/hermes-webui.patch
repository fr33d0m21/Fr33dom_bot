+@router.get("/config", response_model=GatewayConfigResponse)
+async def gateway_config() -> GatewayConfigResponse:
+    """Return structured gateway configuration for the dashboard."""
+    env_values = _read_env_values()
+    config = read_config_yaml()
+
+    platforms = [_build_platform_response(platform, env_values) for platform in _PLATFORM_SPECS]
+
+    return GatewayConfigResponse(
+        gateway_allow_all_users=env_values.get("GATEWAY_ALLOW_ALL_USERS", "").lower() == "true",
+        unauthorized_dm_behavior=str(config.get("unauthorized_dm_behavior", "pair")),
+        platforms=platforms,
+    )
+
+
+@router.patch("/config/{platform}", response_model=GatewayConfigPatchResponse)
+async def patch_gateway_config(platform: str, req: GatewayPlatformPatchRequest) -> GatewayConfigPatchResponse:
+    """Update a platform configuration."""
+    updated_fields: list[str] = []
+    updated_config: list[str] = []
+
+    if platform == "global":
+        for key, value in req.fields.items():
+            if key != "GATEWAY_ALLOW_ALL_USERS":
+                continue
+            normalized = "true" if str(value).lower() == "true" else "false"
+            _set_env_value(key, normalized)
+            updated_fields.append(key)
+
+        for key, value in req.config.items():
+            if key != "unauthorized_dm_behavior":
+                continue
+            write_config_yaml_value(key, value)
+            updated_config.append(key)
+
+        return GatewayConfigPatchResponse(
+            success=True,
+            platform=platform,
+            updated_fields=updated_fields,
+            updated_config=updated_config,
+        )
+
+    spec = _PLATFORMS_BY_KEY.get(platform)
+    if not spec:
+        raise HTTPException(status_code=404, detail="Unknown gateway platform")
+
+    spec_field_keys = {field["key"] for field in spec["fields"]}
+    current_env = _read_env_values()
+
+    for key, value in req.fields.items():
+        if key not in spec_field_keys:
+            continue
+        rendered = str(value or "").strip()
+        field_spec = next((field for field in spec["fields"] if field["key"] == key), None)
+        if not field_spec:
+            continue
+        if field_spec.get("sensitive") and not rendered:
+            continue
+        _set_env_value(key, rendered)
+        updated_fields.append(key)
+
+    for key, value in req.config.items():
+        write_config_yaml_value(key, value)
+        updated_config.append(key)
+
+    if platform == "whatsapp" and current_env.get("WHATSAPP_ENABLED", "").lower() != "true":
+        if str(req.fields.get("WHATSAPP_ENABLED", "")).lower() == "true":
+            updated_fields.append("WHATSAPP_PAIRING_REQUIRED")
+
+    return GatewayConfigPatchResponse(
+        success=True,
+        platform=platform,
+        updated_fields=updated_fields,
+        updated_config=updated_config,
+    )
+
+
+@router.post("/test/{platform}", response_model=GatewayTestResponse)
+async def test_gateway_platform(platform: str) -> GatewayTestResponse:
+    """Test or validate a gateway configuration."""
+    spec = _PLATFORMS_BY_KEY.get(platform)
+    if not spec:
+        raise HTTPException(status_code=404, detail="Unknown gateway platform")
+
+    env_values = _read_env_values()
+    missing_fields = _missing_required_fields(spec, env_values)
+    if missing_fields:
+        return GatewayTestResponse(
+            success=False,
+            platform=platform,
+            message="Missing required fields",
+            missing_fields=missing_fields,
+        )
+
+    if platform == "signal":
+        base_url = env_values.get("SIGNAL_HTTP_URL", "").rstrip("/")
+        if base_url:
+            try:
+                async with httpx.AsyncClient(timeout=5.0) as client:
+                    response = await client.get(f"{base_url}/api/v1/check")
+                if response.status_code == 200:
+                    return GatewayTestResponse(success=True, platform=platform, message="signal-cli responded successfully")
+                return GatewayTestResponse(success=False, platform=platform, message=f"signal-cli returned {response.status_code}")
+            except Exception as exc:  # pragma: no cover - network failure path
+                return GatewayTestResponse(success=False, platform=platform, message=f"Could not reach signal-cli: {exc}")
+
+    if platform == "whatsapp":
+        session_file = HERMES_HOME / "whatsapp" / "session" / "creds.json"
+        if session_file.exists():
+            return GatewayTestResponse(success=True, platform=platform, message="WhatsApp session is already paired")
+        return GatewayTestResponse(success=False, platform=platform, message="WhatsApp is enabled but still needs QR pairing")
+
+    return GatewayTestResponse(
+        success=True,
+        platform=platform,
+        message="Required fields are present. Restart the gateway to apply changes.",
+    )
