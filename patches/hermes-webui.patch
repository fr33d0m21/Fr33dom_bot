+    color: 'var(--color-error)',
+  },
+  info: {
+    backgroundColor: 'rgba(99,102,241,0.12)',
+    color: 'var(--color-info)',
+  },
+}
+
+function formatBytes(size: number | null): string {
+  if (size === null) return 'Unknown'
+  if (size < 1024) return `${size} B`
+  if (size < 1024 * 1024) return `${(size / 1024).toFixed(1)} KB`
+  return `${(size / (1024 * 1024)).toFixed(1)} MB`
+}
+
+function parentPath(path: string): string {
+  if (!path) return ''
+  const index = path.lastIndexOf('/')
+  return index === -1 ? '' : path.slice(0, index)
+}
+
+function basename(path: string): string {
+  if (!path) return ''
+  const index = path.lastIndexOf('/')
+  return index === -1 ? path : path.slice(index + 1)
+}
+
+function joinRelativePath(base: string, relative: string): string {
+  const normalizedBase = base.split('/').filter(Boolean)
+  const normalizedRelative = relative.split('/').filter(Boolean)
+  return [...normalizedBase, ...normalizedRelative].join('/')
+}
+
+function buildExactPath(root: FileRootSummary | null, relativePath: string): string {
+  if (!root) return relativePath
+  if (!relativePath) return root.resolved_path
+  const prefix = root.resolved_path.endsWith('/') ? root.resolved_path.slice(0, -1) : root.resolved_path
+  return `${prefix}/${relativePath}`
+}
+
+function buildDownloadHref(rootId: string, path: string): string {
+  const search = new URLSearchParams({
+    root_id: rootId,
+    path,
+  })
+  return `/api/files/download?${search.toString()}`
+}
+
+/** URL is the source of truth for root, open folder, and selected file (Back/Forward stay in sync). */
+function buildFilesSearchParams(options: { root: string; path?: string | null; folder?: string }): URLSearchParams {
+  const next = new URLSearchParams()
+  next.set('root', options.root)
+  if (options.path) {
+    next.set('path', options.path)
+  } else if (options.folder) {
+    next.set('folder', options.folder)
+  }
+  return next
+}
+
+function parseApiError(error: unknown): ParsedApiError {
+  const message = error instanceof Error ? error.message : 'Unexpected error'
+  const apiMatch = message.match(/^API error (\d+):\s*(.*)$/s)
+
+  if (!apiMatch) {
+    return { status: null, detail: message, message }
+  }
+
+  const status = Number(apiMatch[1])
+  const body = apiMatch[2].trim()
+  let detail = body
+
+  if (body) {
+    try {
+      const parsed = JSON.parse(body) as { detail?: unknown }
+      if (typeof parsed.detail === 'string') {
+        detail = parsed.detail
+      }
+    } catch {
+      detail = body
+    }
+  }
+
+  return { status, detail, message }
+}
+
+function isManagedPathError(error: ParsedApiError): boolean {
+  return error.status === 403 && /managed.*personality|personality api|personality/i.test(`${error.detail} ${error.message}`)
+}
+
+function loadFailureMessage(error: unknown, fallback: string): string {
+  const parsed = parseApiError(error)
+
+  if (isManagedPathError(parsed)) {
+    return 'This path is managed in Personality and cannot be edited from Files.'
+  }
+
+  return parsed.detail || fallback
+}
+
+function describeKind(content: FileContentResponse | null): string {
+  if (!content) return 'Unknown'
+  if (content.is_image) return 'Image'
+  if (content.kind === 'text') return 'Text'
+  if (content.kind === 'binary') return 'Binary'
+  return content.kind || 'Unknown'
+}
