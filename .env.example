# Fr33dom Bot — Environment Variables
# Copy to ~/.hermes/.env and fill in your keys

# LLM Provider (pick at least one)
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-opus-4.6

# Optional tool API keys
PARALLEL_API_KEY=
FIRECRAWL_API_KEY=
FAL_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Self-evolution (optional)
HERMES_AGENT_REPO=~/.hermes/hermes-agent
